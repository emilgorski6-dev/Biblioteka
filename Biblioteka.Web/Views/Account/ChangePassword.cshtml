@{
    ViewData["Title"] = "Zmień hasło";
}

<div class="login-body">
    <div class="login-wrapper">
        
        @* NAGŁÓWEK Z IKONĄ TARCZY *@
        <div class="login-header">
            <div class="icon-box shield-icon-box">
                <i class="fa-solid fa-shield-halved"></i>
            </div>
            <h2 class="change-password-title">Zmień hasło</h2>
            <p class="change-password-subtitle">
                Zalogowano z hasłem tymczasowym. Ustaw nowe hasło dla konta: <strong>jkowalski</strong>
            </p>
        </div>

        @* KARTA FORMULARZA *@
        <div class="login-card">
            <form asp-action="ChangePassword" method="post">
                
                @* POLE: NOWE HASŁO *@
                <div class="form-group">
                    <label class="form-label-custom">Nowe hasło</label>
                    <div class="input-with-icon">
                        <i class="fa-solid fa-lock icon"></i>
                        <input type="password" name="NewPassword" placeholder="••••••••" required />
                    </div>
                </div>

                @* POLE: POTWIERDŹ HASŁO *@
                <div class="form-group" style="margin-top: 1.5rem;">
                    <label class="form-label-custom">Potwierdź hasło</label>
                    <div class="input-with-icon">
                        <i class="fa-solid fa-lock icon"></i>
                        <input type="password" name="ConfirmPassword" placeholder="••••••••" required />
                    </div>
                </div>

                @* PRZYCISK *@
                <button type="submit" class="btn-login-submit" style="margin-top: 2rem;">
                    Zmień hasło
                </button>
            </form>
        </div>

    </div>
</div>