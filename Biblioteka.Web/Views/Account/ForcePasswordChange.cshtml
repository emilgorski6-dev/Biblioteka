@model Biblioteka.Web.Models.WymuszenieZmianyHaslaViewModel
@{
    ViewData["Title"] = "Zmień hasło";
}

<div class="login-body">
    <div class="login-wrapper">
        
        <div class="login-header">
            <div class="icon-box shield-icon-box">
                <i class="fa-solid fa-shield-halved"></i>
            </div>
            <h2 class="change-password-title">Zmień hasło</h2>
            <p class="change-password-subtitle">
                @* ZMIANA: Pobieranie loginu z modelu *@
                Zalogowano z hasłem tymczasowym. Ustaw nowe hasło dla konta: <strong>@Model.Login</strong>
            </p>
        </div>

        <div class="login-card">
            @* ZMIANA: Akcja musi pasować do tej w kontrolerze *@
            <form asp-action="ForcePasswordChange" method="post">
                @Html.AntiForgeryToken()
                
                @* ZMIANA: Niezbędne ukryte pola, żeby kontroler wiedział kogo edytuje *@
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="Login" />

                @* POLE: NOWE HASŁO *@
                <div class="form-group">
                    <label class="form-label-custom">Nowe hasło</label>
                    <div class="input-with-icon">
                        <i class="fa-solid fa-lock icon"></i>
                        @* ZMIANA: Powiązanie z modelem *@
                        <input asp-for="NoweHaslo" type="password" placeholder="••••••••" required />
                    </div>
                    <span asp-validation-for="NoweHaslo" class="text-danger"></span>
                </div>

                @* POLE: POTWIERDŹ HASŁO *@
                <div class="form-group" style="margin-top: 1.5rem;">
                    <label class="form-label-custom">Potwierdź hasło</label>
                    <div class="input-with-icon">
                        <i class="fa-solid fa-lock icon"></i>
                        @* ZMIANA: Powiązanie z modelem *@
                        <input asp-for="PotwierdzHaslo" type="password" placeholder="••••••••" required />
                    </div>
                    <span asp-validation-for="PotwierdzHaslo" class="text-danger"></span>
                </div>

                @* PRZYCISK *@
                <button type="submit" class="btn-login-submit" style="margin-top: 2rem;">
                    Zmień hasło
                </button>

                @* ZMIANA: Wyświetlanie błędów walidacji (np. z PasswordValidator) *@
                <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-top: 1rem;"></div>
            </form>
        </div>

    </div>
</div>