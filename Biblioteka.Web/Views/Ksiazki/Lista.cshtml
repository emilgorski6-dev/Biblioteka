@using System.Security.Claims
@{
    bool isAdmin = User.IsInRole("Administrator");
    bool isLibrarian = User.IsInRole("Bibliotekarz");
    string sidebarTitle = isAdmin ? "Panel administratora" : "Panel bibliotekarza";
    ViewData["Title"] = "Katalog Książek";

    // --- LOGIKA DLA KOMUNIKATÓW (Symulacja danych) ---
    // W prawdziwym systemie te wartości będą pochodzić z Modelu/Bazy danych
    bool hasAnyBooks = true; // Zmień na false, aby zobaczyć komunikat o braku książek
    bool hasFilterResults = true; // Zmień na false, aby zobaczyć komunikat o braku wyników filtrowania
    bool isFilterActive = false; // Flaga sprawdzająca, czy użytkownik kliknął "Zastosuj filtry"
}

<div class="management-panel-layout">
    @* --- SIDEBAR --- *@
    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-icon-box">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E67E22" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    @if (isAdmin) { <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path> }
                    else { <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path> }
                </svg>
            </div>
            <div class="sidebar-titles">
                <h3 class="sidebar-title">@sidebarTitle</h3>
                <p class="sidebar-subtitle">Zarządzanie księgozbiorem Biblioteka Nova</p>
            </div>
        </div>
        <nav class="sidebar-nav">
            <a asp-controller="Ksiazki" asp-action="Lista" class="sidebar-link active">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
                Lista książek
            </a>
            <a asp-controller="Ksiazki" asp-action="Zarejestruj" class="sidebar-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line><rect x="3" y="3" width="18" height="18" rx="2"></rect></svg>
                Zarejestruj książkę
            </a>
        </nav>
    </aside>

    @* --- MAIN CONTENT --- *@
    <main class="management-content">
        <div class="catalog-container">
            
            @* --- KOMUNIKAT O SUKCESIE --- *@
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="alert-icon">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                        <polyline points="22 4 12 14.01 9 11.01"></polyline>
                    </svg>
                    <span>@TempData["SuccessMessage"]</span>
                </div>
            }

            <header class="catalog-header">
                <h1 class="catalog-main-title">Katalog Książek</h1>
                <p class="catalog-subtitle">Przeszukuj zbiory biblioteczne.</p>
            </header>

            @* --- SYSTEM FILTROWANIA --- *@
            <div class="filter-wrapper">
                <div class="filter-top-bar">
                    <button class="btn-top-filter" id="btnToggleFilters">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon></svg>
                        Filtruj
                    </button>
                </div>

                <div class="filter-card" id="filterCard" style="display: none;">
                    <p class="filter-instruction">Wybierz kategorie filtrowania</p>
                    
                    @* Kategoria: Autor *@
                    <div class="filter-category">
                        <div class="category-header">
                            <div class="header-left">
                                <label class="custom-checkbox">
                                    <input type="checkbox" onchange="handleFilterToggle(this)">
                                    <span class="checkmark"></span>
                                </label>
                                <span class="category-name">Autor</span>
                            </div>
                            <svg class="chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
                        </div>
                        <div class="category-content grid-3">
                            <label class="option-item"><input type="checkbox"> Andrzej Sapkowski</label>
                            <label class="option-item"><input type="checkbox"> Antoine de Saint-Exupéry</label>
                            <label class="option-item"><input type="checkbox"> Fiodor Dostojewski</label>
                            <label class="option-item"><input type="checkbox"> George Orwell</label>
                            <label class="option-item"><input type="checkbox"> J.K. Rowling</label>
                            <label class="option-item"><input type="checkbox"> J.R.R. Tolkien</label>
                            <label class="option-item"><input type="checkbox"> Jane Austen</label>
                            <label class="option-item"><input type="checkbox"> Stephen King</label>
                        </div>
                    </div>

                    @* Pozostałe kategorie *@
                    @foreach (var cat in new[] { "Tytuł", "Gatunek", "Wydawnictwo", "Status książki" })
                    {
                        <div class="filter-category">
                            <div class="category-header">
                                <div class="header-left">
                                    <label class="custom-checkbox">
                                        <input type="checkbox" onchange="handleFilterToggle(this)">
                                        <span class="checkmark"></span>
                                    </label>
                                    <span class="category-name">@cat</span>
                                </div>
                                <svg class="chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
                            </div>
                            <div class="category-content grid-3">
                                @if(cat == "Status książki") {
                                    <label class="option-item"><input type="checkbox"> Dostępna</label>
                                    <label class="option-item"><input type="checkbox"> Wypożyczona</label>
                                    <label class="option-item"><input type="checkbox"> Zarezerwowana</label>
                                } else {
                                    <label class="option-item"><input type="checkbox"> Opcja przykładowa 1</label>
                                    <label class="option-item"><input type="checkbox"> Opcja przykładowa 2</label>
                                }
                            </div>
                        </div>
                    }

                    <div class="filter-footer">
                        <button class="btn-clear">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                            Wyczyść
                        </button>
                        <button class="btn-apply">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Zastosuj filtry
                        </button>
                    </div>
                </div>
            </div>

            @* --- WYŚWIETLANIE TABELI LUB KOMUNIKATÓW BRAKU DANYCH --- *@
            @if (!hasAnyBooks)
            {
                <div class="empty-state-card">
                    <div class="empty-state-icon">📁</div>
                    <p class="empty-state-text">Nie zarejestrowano jeszcze żadnych książek</p>
                    <a asp-action="Zarejestruj" class="btn-submit-orange" style="text-decoration: none; margin-top: 15px;">Zarejestruj pierwszą książkę</a>
                </div>
            }
            else if (!hasFilterResults)
            {
                <div class="empty-state-card">
                    <div class="empty-state-icon">🔍</div>
                    <p class="empty-state-text">Brak książek spełniających kryteria filtrowania</p>
                    @* Opcjonalnie: <p class="empty-state-subtext">Brak rejestracji spełniających kryteria filtrowania</p> *@
                </div>
            }
            else
            {
                <div class="books-card-table">
                    <div class="table-header-row">
                        <div class="col-main">Tytuł i Autor</div>
                        <div class="col-info">Kategoria & Rok</div>
                        <div class="col-isbn">ISBN</div>
                        <div class="col-status">Status</div>
                        <div class="col-link"></div>
                    </div>
                    <div class="table-body">
                        <div class="book-item-row">
                            <div class="col-main">
                                <div class="book-icon-bg"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3498db" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg></div>
                                <div class="book-text-info">
                                    <span class="book-title">Władca Pierścieni: Drużyna Pierścienia</span>
                                    <span class="book-author">J.R.R. Tolkien</span>
                                </div>
                            </div>
                            <div class="col-info"><span class="book-cat">Fantastyka</span><span class="book-year">1954</span></div>
                            <div class="col-isbn"><span class="isbn-pill">978-83-241-5506-6</span></div>
                            <div class="col-status"><span class="status-badge available">Dostępna</span></div>
                            <div class="col-link">
                                <a asp-controller="Ksiazki" asp-action="Szczegoly" asp-route-id="1" class="details-orange-link">Szczegóły</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </main>
</div>

<script>
    // Toggle całej karty filtrów
    document.getElementById('btnToggleFilters').addEventListener('click', function() {
        const card = document.getElementById('filterCard');
        card.style.display = (card.style.display === 'none') ? 'block' : 'none';
    });

    // Rozwijanie sekcji TYLKO po zmianie checkboxa
    function handleFilterToggle(checkbox) {
        const categoryDiv = checkbox.closest('.filter-category');
        const chevron = categoryDiv.querySelector('.chevron polyline');
        
        if (checkbox.checked) {
            categoryDiv.classList.add('active');
            chevron.setAttribute('points', '18 15 12 9 6 15');
        } else {
            categoryDiv.classList.remove('active');
            chevron.setAttribute('points', '6 9 12 15 18 9');
        }
    }
</script>