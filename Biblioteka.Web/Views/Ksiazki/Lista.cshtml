@model IEnumerable<Biblioteka.Web.Models.KsiazkaListaViewModel>
@using System.Security.Claims
@{
    bool isAdmin = User.IsInRole("Administrator");
    bool isLibrarian = User.IsInRole("Bibliotekarz");
    string sidebarTitle = isAdmin ? "Panel administratora" : "Panel bibliotekarza";
    ViewData["Title"] = "Katalog Książek";

    bool hasAnyBooks = Model != null && Model.Any();
    bool isFilterActive = ViewBag.IsFilterActive ?? false;
    bool hasFilterResults = !isFilterActive || (isFilterActive && hasAnyBooks);
}

<div class="management-panel-layout">
    @* --- SIDEBAR --- *@
    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-icon-box">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E67E22" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    @if (isAdmin)
                    {
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                    }
                    else
                    {
                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                    }
                </svg>
            </div>
            <div class="sidebar-titles">
                <h3 class="sidebar-title">@sidebarTitle</h3>
                <p class="sidebar-subtitle">Zarządzanie księgozbiorem Biblioteka Nova</p>
            </div>
        </div>
        <nav class="sidebar-nav">
            <a asp-controller="Ksiazki" asp-action="Lista" class="sidebar-link active">Lista książek</a>
            <a asp-controller="Ksiazki" asp-action="Zarejestruj" class="sidebar-link">Zarejestruj książkę</a>
        </nav>
    </aside>

    <main class="management-content">
        <div class="catalog-container">
            
            @* --- KOMUNIKAT O SUKCESIE --- *@
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success" id="successAlert">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                         class="alert-icon">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                        <polyline points="22 4 12 14.01 9 11.01"></polyline>
                    </svg>
                    <span>Dodano książkę „@TempData["SuccessMessage"]”.</span>
                </div>
                <script>
                                setTimeout(() => { document.getElementById('successAlert')?.remove(); }, 5000);
                </script>
            }

            <header class="catalog-header">
                <h1 class="catalog-main-title">Katalog Książek</h1>
                <p class="catalog-subtitle">Przeszukuj zbiory biblioteczne.</p>
            </header>

            @* --- SYSTEM FILTROWANIA --- *@
            <div class="filter-wrapper">
                <form method="get" asp-action="Lista" class="filter-top-bar">
                    <input type="text" name="searchString" value="@ViewBag.CurrentFilter"
                           placeholder="Szukaj po tytule lub autorze..."
                           style="padding: 8px; border-radius: 4px; border: 1px solid #ddd; width: 300px;">
                    <button type="submit" class="btn-top-filter">Szukaj</button>
                    @if (isFilterActive)
                    {
                        <a asp-action="Lista" class="btn-clear" style="text-decoration:none; line-height:30px;">X</a>
                    }
                </form>
            </div>

            @if (!hasAnyBooks && !isFilterActive)
            {
                <div class="empty-state-card">
                    <div class="empty-state-icon">📁</div>
                    <p class="empty-state-text">Nie zarejestrowano jeszcze żadnych książek</p>
                    <a asp-action="Zarejestruj" class="btn-submit-orange"
                       style="text-decoration: none; margin-top: 15px;">Zarejestruj pierwszą książkę</a>
                </div>
            }
            else if (!hasAnyBooks && isFilterActive)
            {
                <div class="empty-state-card">
                    <div class="empty-state-icon">🔍</div>
                    <p class="empty-state-text">Brak książek spełniających kryteria filtrowania</p>
                </div>
            }
            else
            {
                <div class="books-card-table">
                    <div class="table-header-row">
                        <div class="col-main">Tytuł i Autor</div>
                        <div class="col-info">Kategoria & Rok</div>
                        <div class="col-status">Status</div>
                        <div class="col-link"></div>
                    </div>
                    <div class="table-body">
                        @foreach (var item in Model ?? Enumerable.Empty<Biblioteka.Web.Models.KsiazkaListaViewModel>())
                        {
                            if (item == null) continue;

                            <div class="book-item-row">
                                <div class="col-main">
                                    <div class="book-icon-bg">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3498db"
                                             stroke-width="2">
                                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                                        </svg>
                                    </div>
                                    <div class="book-text-info">
                                        <span class="book-title">@(item.Tytul ?? "Brak tytułu")</span>
                                        <span class="book-author">@(item.Autor ?? "Brak autora")</span>
                                    </div>
                                </div>
                                <div class="col-info">
                                    <span class="book-cat">@(item.Gatunek ?? "Brak gatunku")</span>
                                    <span class="book-year">@(item.RokWydania?.ToString() ?? "Brak danych")</span>
                                </div>
                                <div class="col-status">
                                    <span class="status-badge @(item.Status == "Dostępna" ? "available" : "borrowed")">
                                        @(item.Status ?? "Nieznany")
                                    </span>
                                </div>
                                <div class="col-link" style="display: flex; gap: 15px; align-items: center;">
                                    <a asp-action="Szczegoly" asp-route-id="@item.Id" class="details-orange-link">Szczegóły</a>
                                    
                                    @* DODANO: Link zgodny ze scenariuszem alternatywnym ZRK-01 *@
                                    <a asp-action="ZarejestrujZListy" asp-route-id="@item.Id"
                                       class="details-orange-link">Zarejestruj książkę</a>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </main>
</div>