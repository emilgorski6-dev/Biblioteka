@model IEnumerable<Biblioteka.Web.Models.WypozyczenieViewModel>
@{
    bool isAdmin = User.IsInRole("Administrator");
    bool isLibrarian = User.IsInRole("Bibliotekarz");
    bool isManager = User.IsInRole("Manager");
    string sidebarTitle = isAdmin ? "Panel Administratora" : isLibrarian ? "Panel Bibliotekarza" : "Panel Managera";
    ViewData["Title"] = "Lista wypożyczeń";

    bool hasAnyLoans = ViewBag.HasAnyLoans ?? true;
    bool hasFilterResults = ViewBag.HasFilterResults ?? true;
    
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<div class="management-panel-layout">
    @* --- SIDEBAR (Zgodny z image_767c40.png oraz image_767cb8.png) --- *@
    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-icon-box">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E67E22" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
                    <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
                </svg>
            </div>
            <div class="sidebar-titles">
                <h3 class="sidebar-title">@sidebarTitle</h3>
                <p class="sidebar-subtitle">Zarządzanie systemem Biblioteka Nova</p>
            </div>
        </div>
        <nav class="sidebar-nav">
            @* Link: Lista książek *@
            <a asp-controller="Ksiazki" asp-action="Lista" class="sidebar-link @(currentAction == "Lista" ? "active" : "")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;">
                    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                    <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                </svg>
                Lista książek
            </a>

            @* Link: Lista rejestracji książek (Zamiast "Zarejestruj książkę" - image_767cb8.png) *@
            <a asp-controller="Manager" asp-action="Rejestracje" class="sidebar-link @(currentAction == "Rejestracje" ? "active" : "")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="3" y1="9" x2="21" y2="9"></line>
                    <line x1="9" y1="21" x2="9" y2="9"></line>
                </svg>
                Lista rejestracji książek
            </a>

            @if (isLibrarian)
            {
                <a asp-controller="Ksiazki" asp-action="RejestracjaWypozyczen" class="sidebar-link @(currentAction == "RejestracjaWypozyczen" ? "active" : "")">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;">
                        <path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path>
                    </svg>
                    Rejestracja wypożyczeń
                </a>
            }

            <a asp-controller="Ksiazki" asp-action="ListaWypozyczen" class="sidebar-link @(currentAction == "ListaWypozyczen" ? "active" : "")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                    <line x1="16" y1="13" x2="8" y2="13"></line>
                    <line x1="16" y1="17" x2="8" y2="17"></line>
                </svg>
                Lista wypożyczeń
            </a>
        </nav>
    </aside>

    @* --- MAIN CONTENT --- *@
    <main class="management-content">
        <div class="form-container">
            
            @* --- TOAST (Komunikat o sukcesie) --- *@
            @if (TempData["SuccessMessage"] != null)
            {
                <div id="successToast" class="toast-container-top-right">
                    <div class="toast-alert">
                        <div class="toast-check-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"></polyline>
                            </svg>
                        </div>
                        <div class="toast-message">
                            @TempData["SuccessMessage"]
                        </div>
                    </div>
                </div>
            }

            <header class="loan-page-header">
                <h1 class="loan-main-title">Lista wypożyczeń</h1>
                <p class="loan-subtitle">Przeglądaj historię wypożyczeń, przedłużaj terminy i rejestruj zwroty książek.</p>
            </header>

            @if (!hasAnyLoans)
            {
                <div class="empty-state-card" style="margin-top: 40px;">
                    <div class="empty-state-icon">📂</div>
                    <p class="empty-state-text">Nie dokonano jeszcze żadnego wypożyczenia.</p>
                </div>
            }
            else
            {
                @* --- KARTA FILTROWANIA --- *@
                <div class="filter-box-white">
                    <div class="filter-box-header">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon></svg>
                        Filtrowanie
                    </div>
                    
                    <form method="get" asp-action="ListaWypozyczen">
                        <div class="filter-grid-4">
                            <div class="filter-group">
                                <label>Wypożyczający</label>
                                <div class="search-input-wrapper">
                                    <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                                    <input type="text" id="wypozyczajacyInput" name="wypozyczajacy" placeholder="Imię i nazwisko" value="@ViewBag.Wypozyczajacy" autocomplete="off" class="form-control-input">
                                    <div id="wypozyczajacySuggestions" class="autocomplete-dropdown" style="display:none;"></div>
                                </div>
                            </div>

                            <div class="filter-group">
                                <label>Bibliotekarz</label>
                                <select name="bibliotekarz" class="form-control-select">
                                    <option value="Wszyscy bibliotekarze" selected="@(ViewBag.Bibliotekarz == null || ViewBag.Bibliotekarz == "Wszyscy bibliotekarze")">
                                        Wszyscy bibliotekarze
                                    </option>
                                    @foreach (var item in ViewBag.ListaBibliotekarzy as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>())
                                    {
                                        <option value="@item.Value" selected="@(ViewBag.Bibliotekarz == item.Value)">
                                            @item.Text
                                        </option>
                                    }
                                </select>
                            </div>

                            <div class="filter-group">
                                <label>Okres wypożyczenia</label>
                                <div class="date-range-group">
                                    <input type="date" name="dataOd" class="form-control-date" value="@ViewBag.DataOd">
                                    <span class="date-separator">-</span>
                                    <input type="date" name="dataDo" class="form-control-date" value="@ViewBag.DataDo">
                                </div>
                            </div>

                            <div class="filter-group">
                                <label>Status wypożyczenia</label>
                                <select name="status" class="form-control-select">
                                    <option value="Wszystkie statusy" selected="@(ViewBag.Status == "Wszystkie statusy")">Wszystkie statusy</option>
                                    <option value="Nowe" selected="@(ViewBag.Status == "Nowe")">Nowe</option>
                                    <option value="Przedłużone" selected="@(ViewBag.Status == "Przedłużone")">Przedłużone</option>
                                    <option value="Zakończone" selected="@(ViewBag.Status == "Zakończone")">Zakończone</option>
                                </select>
                            </div>
                        </div>

                        <div class="filter-actions-right">
                            <a href="@Url.Action("ListaWypozyczen")" class="btn-cancel" style="text-decoration:none;">Anuluj</a>
                            <button type="submit" class="btn-submit-orange">Filtruj</button>
                        </div>
                    </form>
                </div>

                @* --- TABELA --- *@
                @if (!hasFilterResults)
                {
                    <div class="empty-state-card" style="margin-top: 20px;">
                        <div class="empty-state-icon">🔍</div>
                        <p class="empty-state-text">Brak wyników spełniających kryteria filtrowania.</p>
                    </div>
                }
                else
                {
                    <div class="books-card-table" style="margin-top: 25px;">
                        <div class="table-header-row list-wyp-grid">
                            <div class="col-header">Wypożyczający</div>
                            <div class="col-header">Książka</div>
                            <div class="col-header">Data wypożyczenia</div>
                            <div class="col-header">Data zwrotu</div>
                            <div class="col-header">Status</div>
                            <div class="col-header">Bibliotekarz</div>
                            <div class="col-header"></div>
                        </div>
                        <div class="table-body">
                            @foreach (var item in Model)
                            {
                                <div class="book-item-row list-wyp-grid">
                                    <div class="col-cell" style="font-weight: 600; color: #333;">@item.Wypozyczajacy</div>
                                    <div class="col-cell" style="color: #555;">@item.Ksiazka</div>
                                    <div class="col-cell" style="color: #666;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:5px; min-width:14px;"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg> @item.DataWypozyczenia.ToString("yyyy-MM-dd")</div>
                                    <div class="col-cell" style="color: #666;">@item.DataZwrotu.ToString("yyyy-MM-dd")</div>
                                    <div class="col-cell">
                                        @if (item.Status == "Nowe") {
                                            <span class="status-badge-custom badge-new"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg> Nowe</span>
                                        } else if (item.Status == "Przedłużone") {
                                            <span class="status-badge-custom badge-extended"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg> Przedłużone</span>
                                        } else if (item.Status == "Zakończone") {
                                            <span class="status-badge-custom badge-finished"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg> Zakończone</span>
                                        }
                                    </div>
                                    <div class="col-cell" style="color: #777;">@item.Bibliotekarz</div>
                                    
                                    <div class="col-cell action-buttons-container" style="justify-content: flex-end; display: flex; gap: 8px;">
                                        @if (item.Status == "Nowe" || item.Status == "Przedłużone")
                                        {
                                            <button type="button" class="btn-extend-outline" onclick="openExtendModal(@item.Id, '@item.Wypozyczajacy')">Przedłuż</button>
                                            <button type="button" class="btn-return-outline" onclick="openReturnModal(@item.Id, '@item.Wypozyczajacy')">Zwróć</button>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </main>
</div>

@* --- MODALE (BEZ ZMIAN) --- *@
<div id="extendModal" class="perm-modal-overlay" style="display: none; align-items: center; justify-content: center; z-index: 100000; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5);">
    <div class="perm-modal-content" style="background: white; border-radius: 12px; padding: 30px; width: 100%; max-width: 450px; box-shadow: 0 10px 25px rgba(0,0,0,0.2);">
        <h3 style="margin-top: 0; margin-bottom: 20px; font-size: 1.25rem; font-weight: 700; color: #333;">Przedłużenie wypożyczenia</h3>
        <p style="color: #555; margin-bottom: 30px; line-height: 1.5;">
            Czy na pewno chcesz przedłużyć wypożyczenie użytkownika <strong id="extendUserName" style="color: #111;"></strong>?
        </p>
        <div style="display: flex; justify-content: flex-end; gap: 12px;">
            <button type="button" onclick="closeExtendModal()" class="btn-cancel" style="border: 1px solid #ccc; padding: 10px 20px; border-radius: 8px; background: white; cursor: pointer;">Anuluj</button>
            <form asp-action="PrzedluzWypozyczenie" method="post" style="margin: 0;">
                <input type="hidden" name="id" id="extendLoanId" />
                <button type="submit" class="btn-submit-orange">Tak</button>
            </form>
        </div>
    </div>
</div>

<div id="returnModal" class="perm-modal-overlay" style="display: none; align-items: center; justify-content: center; z-index: 100000; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5);">
    <div class="perm-modal-content" style="background: white; border-radius: 12px; padding: 30px; width: 100%; max-width: 450px; box-shadow: 0 10px 25px rgba(0,0,0,0.2);">
        <h3 style="margin-top: 0; margin-bottom: 20px; font-size: 1.25rem; font-weight: 700; color: #333;">Zwrot książek</h3>
        <p style="color: #555; margin-bottom: 30px; line-height: 1.5;">
            Czy na pewno chcesz dokonać zwrotu książek użytkownika <strong id="returnUserName" style="color: #111;"></strong>?
        </p>
        <div style="display: flex; justify-content: flex-end; gap: 12px;">
            <button type="button" onclick="closeReturnModal()" class="btn-cancel" style="border: 1px solid #ccc; padding: 10px 20px; border-radius: 8px; background: white; cursor: pointer;">Anuluj</button>
            <form asp-action="ZwrotWypozyczenia" method="post" style="margin: 0;">
                <input type="hidden" name="id" id="returnLoanId" />
                <button type="submit" class="btn-submit-green">Tak</button>
            </form>
        </div>
    </div>
</div>

<script>
    const mockUsers = ['Jan Kowalski', 'Anna Nowak', 'Magdalena Lewandowska', 'Piotr Wiśniewski', 'Krzysztof Krawczyk'];
    const input = document.getElementById('wypozyczajacyInput');
    const suggBox = document.getElementById('wypozyczajacySuggestions');
    
    if(input) {
        input.addEventListener('input', function() {
            const val = this.value.toLowerCase();
            suggBox.innerHTML = '';
            if (!val) { suggBox.style.display = 'none'; return; }
            const matches = mockUsers.filter(u => u.toLowerCase().includes(val));
            if (matches.length > 0) {
                matches.forEach(match => {
                    const div = document.createElement('div');
                    div.className = 'autocomplete-item';
                    div.innerText = match;
                    div.onclick = () => { input.value = match; suggBox.style.display = 'none'; };
                    suggBox.appendChild(div);
                });
                suggBox.style.display = 'block';
            } else { suggBox.style.display = 'none'; }
        });
        document.addEventListener('click', function(e) { if(e.target !== input) suggBox.style.display = 'none'; });
    }

    function openExtendModal(id, userName) {
        document.getElementById('extendLoanId').value = id;
        document.getElementById('extendUserName').innerText = userName;
        document.getElementById('extendModal').style.display = 'flex';
    }
    function closeExtendModal() { document.getElementById('extendModal').style.display = 'none'; }
    function openReturnModal(id, userName) {
        document.getElementById('returnLoanId').value = id;
        document.getElementById('returnUserName').innerText = userName;
        document.getElementById('returnModal').style.display = 'flex';
    }
    function closeReturnModal() { document.getElementById('returnModal').style.display = 'none'; }

    document.addEventListener('DOMContentLoaded', function() {
        const toast = document.getElementById('successToast');
        if (toast) {
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(20px)';
                setTimeout(() => toast.remove(), 500);
            }, 5000);
        }
    });
</script>

<style>
    .management-content { padding: 10px; }
    .books-card-table { width: 100%; background: white; border-radius: 8px; overflow: hidden; }
    .list-wyp-grid {
        display: grid;
        grid-template-columns: minmax(110px, 1fr) minmax(150px, 1.8fr) 90px 90px 115px minmax(100px, 1fr) 130px;
        gap: 8px; padding: 12px 10px; align-items: center; border-bottom: 1px solid #f0f0f0;
    }
    .col-header { font-size: 0.7rem; font-weight: 800; color: #999; text-transform: uppercase; }
    .col-cell { font-size: 0.85rem; line-height: 1.3; white-space: normal; word-break: break-word; color: #444; }
    .btn-extend-outline, .btn-return-outline { padding: 5px 10px; font-size: 0.75rem; width: 100%; }
    .action-buttons-container { display: flex; flex-direction: column; gap: 4px; }
    .status-badge-custom { padding: 4px 8px; font-size: 0.7rem; display: inline-flex; width: fit-content; }
</style>