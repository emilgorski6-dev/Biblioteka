@{
    bool isAdmin = User.IsInRole("Administrator");
    bool isLibrarian = User.IsInRole("Bibliotekarz");
    string sidebarTitle = isAdmin ? "Panel administratora" : "Panel Bibliotekarza";
    ViewData["Title"] = "Rejestracja wypożyczeń";
}

<div class="management-panel-layout">
    @* --- SIDEBAR --- *@
    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-icon-box">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E67E22" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
            </div>
            <div class="sidebar-titles">
                <h3 class="sidebar-title">@sidebarTitle</h3>
                <p class="sidebar-subtitle">Zarządzanie księgozbiorem Biblioteka Nova</p>
            </div>
        </div>
        <nav class="sidebar-nav">
            <a asp-controller="Ksiazki" asp-action="Lista" class="sidebar-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
                Lista książek
            </a>
            <a asp-controller="Ksiazki" asp-action="Zarejestruj" class="sidebar-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line><rect x="3" y="3" width="18" height="18" rx="2"></rect></svg>
                Zarejestruj książkę
            </a>
            
            @* ZAKŁADKA WIDOCZNA TYLKO DLA BIBLIOTEKARZA *@
            @if (isLibrarian)
            {
                <a asp-controller="Ksiazki" asp-action="RejestracjaWypozyczen" class="sidebar-link active">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path></svg>
                    Rejestracja wypożyczeń
                </a>
                       <a asp-controller="Ksiazki" asp-action="ListaWypozyczen" class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "ListaWypozyczen" ? "active" : "")">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
        Lista wypożyczeń
    </a>
            }
        </nav>
    </aside>

    @* --- MAIN CONTENT --- *@
    <main class="management-content">
        <div class="form-container">
            
            @if (TempData["SuccessMessage"] != null)
            {
                <div id="successToast" class="toast-container-top-right">
                    <div class="toast-alert">
                        <div class="toast-check-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"></polyline>
                            </svg>
                        </div>
                        <div class="toast-message">
                            @TempData["SuccessMessage"]
                        </div>
                    </div>
                </div>
            }

            <header class="loan-page-header">
                <h1 class="loan-main-title">Rejestracja wypożyczeń</h1>
                <p class="loan-subtitle">Wyszukaj klienta oraz książki, aby zarejestrować nowe wypożyczenie.</p>
            </header>

            <form id="loanForm" method="post" asp-action="RejestracjaWypozyczen">
                <input type="hidden" id="hiddenCustomerId" name="customerId" required>
                <div id="hiddenBooksContainer"></div>

                @* SEKCJA 1: KLIENT *@
                <section class="loan-section-card">
                    <div class="section-header">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E67E22" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                        <h2>Dane klienta</h2>
                    </div>
                    
                    <div class="section-content">
                        <div id="customerSearchView">
                            <label>Wyszukaj klienta (imię, nazwisko, adres, telefon)</label>
                            <div class="search-input-wrapper">
                                <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                                <input type="text" id="customerSearchInput" placeholder="Zacznij wpisywać..." autocomplete="off">
                                <div id="customerSuggestions" class="autocomplete-dropdown" style="display:none;"></div>
                            </div>
                        </div>

                        <div id="customerSelectedView" class="selected-box" style="display: none;">
                            <div class="selected-details">
                                <div class="detail-group">
                                    <span class="detail-label">Imię i nazwisko</span>
                                    <strong id="displayCustomerName"></strong>
                                </div>
                                <div class="detail-group">
                                    <span class="detail-label">Numer telefonu</span>
                                    <span id="displayCustomerPhone" class="detail-value"></span>
                                </div>
                            </div>
                            <div class="detail-group full-width">
                                <span class="detail-label">Adres zamieszkania</span>
                                <span id="displayCustomerAddress" class="detail-value"></span>
                            </div>
                            <button type="button" class="btn-change-text" onclick="clearCustomer()">Zmień</button>
                        </div>
                    </div>
                </section>

                @* SEKCJA 2: KSIĄŻKI *@
                <section class="loan-section-card">
                    <div class="section-header">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E67E22" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                        <h2>Wypożyczane książki</h2>
                    </div>
                    
                    <div class="section-content">
                        <div class="search-input-wrapper">
                            <label>Wyszukaj książkę (tytuł, autor)</label>
                            <div style="position: relative;">
                                <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                                <input type="text" id="bookSearchInput" placeholder="Szukaj dostępnych książek..." autocomplete="off">
                                <div id="bookSuggestions" class="autocomplete-dropdown" style="display:none;"></div>
                            </div>
                        </div>

                        <div id="selectedBooksArea" style="display: none; margin-top: 25px;">
                            <label>Wybrane pozycje:</label>
                            <ul id="selectedBooksList" class="selected-items-list"></ul>
                            
                            <button type="button" class="btn-add-another" onclick="document.getElementById('bookSearchInput').focus()">
                                + Dodaj kolejną książkę
                            </button>
                        </div>
                    </div>
                </section>

                @* SEKCJA 3: SZCZEGÓŁY *@
                <section class="loan-section-card">
                    <div class="section-header">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E67E22" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                        <h2>Szczegóły wypożyczenia</h2>
                    </div>
                    
                    <div class="section-content">
                        <div class="input-group" style="max-width: 300px;">
                            <label>Czas wypożyczenia</label>
                            <select name="duration" class="form-control-select">
                                <option value="2w">2 tygodnie (standardowo)</option>
                                <option value="1m">1 miesiąc</option>
                                <option value="2m">2 miesiące</option>
                            </select>
                        </div>
                    </div>
                </section>

                <div class="loan-form-footer">
                    <button type="button" class="btn-cancel" onclick="window.history.back()">Anuluj</button>
                    <button type="submit" id="btnSubmitLoan" class="btn-submit-orange" disabled>Wypożycz</button>
                </div>
            </form>
        </div>
    </main>
</div>

<script>
    // System powiadomień Toast
    document.addEventListener('DOMContentLoaded', function() {
        const toast = document.getElementById('successToast');
        if (toast) {
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(20px)';
                setTimeout(() => toast.remove(), 500);
            }, 5000);
        }
    });

    // Baza symulacyjna (Kroki 4 i 8 analizy)
    const mockCustomers = [
        { id: 1, name: 'Jan Kowalski', phone: '123-456-789', address: 'ul. Kwiatowa 1, Warszawa' },
        { id: 2, name: 'Anna Nowak', phone: '987-654-321', address: 'ul. Długa 15, Kraków' }
    ];

    const mockBooks = [
        { id: 101, title: 'Zbrodnia i kara', author: 'Fiodor Dostojewski' },
        { id: 102, title: 'Władca Pierścieni', author: 'J.R.R. Tolkien' },
        { id: 103, title: 'Wiedźmin', author: 'Andrzej Sapkowski' }
    ];

    const custSearchInp = document.getElementById('customerSearchInput');
    const custSuggBox = document.getElementById('customerSuggestions');
    
    // Krok 3-6: Wyszukiwanie i wybór klienta
    custSearchInp.addEventListener('input', function() {
        const val = this.value.toLowerCase();
        custSuggBox.innerHTML = '';
        if (!val) { custSuggBox.style.display = 'none'; return; }

        const matches = mockCustomers.filter(c => c.name.toLowerCase().includes(val) || c.phone.includes(val));
        if (matches.length > 0) {
            matches.forEach(c => {
                const div = document.createElement('div');
                div.className = 'autocomplete-item';
                div.innerHTML = `<strong>${c.name}</strong> <span style="color:#777; font-size:0.85rem;">(${c.phone})</span>`;
                div.onclick = () => selectCustomer(c);
                custSuggBox.appendChild(div);
            });
            custSuggBox.style.display = 'block';
        } else {
            custSuggBox.style.display = 'none';
        }
    });

    function selectCustomer(c) {
        document.getElementById('hiddenCustomerId').value = c.id;
        document.getElementById('displayCustomerName').innerText = c.name;
        document.getElementById('displayCustomerPhone').innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:5px; vertical-align:middle;"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>` + c.phone;
        document.getElementById('displayCustomerAddress').innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:5px; vertical-align:middle;"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>` + c.address;
        
        document.getElementById('customerSearchView').style.display = 'none';
        document.getElementById('customerSelectedView').style.display = 'flex';
        custSuggBox.style.display = 'none';
        custSearchInp.value = '';
        validateForm();
    }

    function clearCustomer() {
        document.getElementById('hiddenCustomerId').value = '';
        document.getElementById('customerSearchView').style.display = 'block';
        document.getElementById('customerSelectedView').style.display = 'none';
        validateForm();
    }

    // Krok 7-11: Wyszukiwanie, wybór i listowanie książek
    let selectedBooksData = [];
    const bookSearchInp = document.getElementById('bookSearchInput');
    const bookSuggBox = document.getElementById('bookSuggestions');
    const selectedBooksList = document.getElementById('selectedBooksList');

    bookSearchInp.addEventListener('input', function() {
        const val = this.value.toLowerCase();
        bookSuggBox.innerHTML = '';
        if (!val) { bookSuggBox.style.display = 'none'; return; }

        const availableBooks = mockBooks.filter(b => !selectedBooksData.some(sb => sb.id === b.id));
        const matches = availableBooks.filter(b => b.title.toLowerCase().includes(val) || b.author.toLowerCase().includes(val));
        
        if (matches.length > 0) {
            matches.forEach(b => {
                const div = document.createElement('div');
                div.className = 'autocomplete-item';
                div.innerHTML = `<strong>${b.title}</strong> <span style="color:#777; font-size:0.85rem;">- ${b.author}</span>`;
                div.onclick = () => addBook(b);
                bookSuggBox.appendChild(div);
            });
            bookSuggBox.style.display = 'block';
        } else {
            bookSuggBox.style.display = 'none';
        }
    });

    function addBook(b) {
        selectedBooksData.push(b);
        bookSearchInp.value = '';
        bookSuggBox.style.display = 'none';
        renderBooks();
    }

    function removeBook(id) {
        selectedBooksData = selectedBooksData.filter(b => b.id !== id);
        renderBooks();
    }

    function renderBooks() {
        selectedBooksList.innerHTML = '';
        const hiddenContainer = document.getElementById('hiddenBooksContainer');
        hiddenContainer.innerHTML = '';

        if (selectedBooksData.length > 0) {
            document.getElementById('selectedBooksArea').style.display = 'block';
            
            selectedBooksData.forEach(b => {
                const li = document.createElement('li');
                li.className = 'selected-book-item';
                li.innerHTML = `
                    <div class="book-meta">
                        <strong class="book-title">${b.title}</strong>
                        <span class="book-author">${b.author}</span>
                    </div>
                    <button type="button" class="btn-delete-book" onclick="removeBook(${b.id})">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                    </button>
                `;
                selectedBooksList.appendChild(li);

                const hiddenInput = document.createElement('input');
                hiddenInput.type = 'hidden';
                hiddenInput.name = 'bookIds';
                hiddenInput.value = b.id;
                hiddenContainer.appendChild(hiddenInput);
            });
        } else {
            document.getElementById('selectedBooksArea').style.display = 'none';
        }
        validateForm();
    }

    document.addEventListener('click', function(e) {
        if(e.target !== custSearchInp) custSuggBox.style.display = 'none';
        if(e.target !== bookSearchInp) bookSuggBox.style.display = 'none';
    });

    // Wymagania: Wypożycz możliwe tylko, gdy jest klient i min. 1 książka
    function validateForm() {
        const hasCustomer = document.getElementById('hiddenCustomerId').value !== '';
        const hasBooks = selectedBooksData.length > 0;
        const btn = document.getElementById('btnSubmitLoan');
        
        btn.disabled = !(hasCustomer && hasBooks);
        if(btn.disabled) {
            btn.style.opacity = '0.5';
            btn.style.cursor = 'not-allowed';
        } else {
            btn.style.opacity = '1';
            btn.style.cursor = 'pointer';
        }
    }
</script>