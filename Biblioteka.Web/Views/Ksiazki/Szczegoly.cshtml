@using System.Security.Claims
@{
    bool isAdmin = User.IsInRole("Administrator");
    bool isLibrarian = User.IsInRole("Bibliotekarz");
    string sidebarTitle = isAdmin ? "Panel administratora" : "Panel bibliotekarza";
    ViewData["Title"] = "Szczegóły książki";
}

<div class="management-panel-layout">
    @* --- SIDEBAR --- *@
    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-icon-box">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E67E22" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    @if (isAdmin) { <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path> }
                    else { <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path> }
                </svg>
            </div>
            <div class="sidebar-titles">
                <h3 class="sidebar-title">@sidebarTitle</h3>
                <p class="sidebar-subtitle">Zarządzanie księgozbiorem Biblioteka Nova</p>
            </div>
        </div>
        <nav class="sidebar-nav">
            <a asp-controller="Ksiazki" asp-action="Lista" class="sidebar-link active">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
                Lista książek
            </a>
            <a asp-controller="Ksiazki" asp-action="Zarejestruj" class="sidebar-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line><rect x="3" y="3" width="18" height="18" rx="2"></rect></svg>
                Zarejestruj książkę
            </a>
        </nav>
    </aside>

    @* --- GŁÓWNA TREŚĆ --- *@
    <main class="management-content">
        <div class="details-container">
            @* Powrót *@
            <a asp-controller="Ksiazki" asp-action="Lista" class="back-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                Powrót do listy
            </a>

            @* Karta szczegółów *@
            <div class="book-details-card">
                <div class="details-header">
                    <div class="details-icon-box">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#3498db" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
                    </div>
                    <div class="details-main-info">
                        <h1 class="details-title">Władca Pierścieni: Drużyna Pierścienia</h1>
                        <p class="details-author">J.R.R. Tolkien</p>
                        <span class="status-badge available">Dostępna</span>
                    </div>
                </div>

                <div class="details-grid">
                    <div class="grid-item">
                        <label>Gatunek</label>
                        <span>Fantastyka</span>
                    </div>
                    <div class="grid-item">
                        <label>Rok wydania</label>
                        <span>1954</span>
                    </div>
                    <div class="grid-item">
                        <label>ISBN</label>
                        <span>978-83-241-5506-6</span>
                    </div>
                    <div class="grid-item">
                        <label>Wydawnictwo</label>
                        <span>Amber</span>
                    </div>
                    <div class="grid-item">
                        <label>Liczba stron</label>
                        <span>512</span>
                    </div>
                    <div class="grid-item">
                        <label>Cena</label>
                        <span>49.99 zł</span>
                    </div>
                    <div class="grid-item">
                        <label>Liczba sztuk</label>
                        <span>3</span>
                    </div>
                </div>

                <div class="details-description">
                    <label>Opis</label>
                    <p>Pierwsza część legendarnej trylogii.</p>
                </div>

                <div class="details-footer">
                    @* --- KLUCZOWA ZMIANA: Przycisk jako link do rejestracji --- *@
                    <a asp-controller="Ksiazki" asp-action="Zarejestruj" class="btn-register-action">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line><rect x="3" y="3" width="18" height="18" rx="2"></rect></svg>
                        Zarejestruj książkę
                    </a>
                </div>
            </div>
        </div>
    </main>
</div>