@model Biblioteka.Web.Models.KsiazkaListaViewModel
@using System.Security.Claims
@{
    bool isAdmin = User.IsInRole("Administrator");
    bool isLibrarian = User.IsInRole("Bibliotekarz");
    bool isManager = User.IsInRole("Manager");

    string sidebarTitle = isAdmin ? "Panel Administratora" :
                        isManager ? "Panel Managera" :
                        isLibrarian ? "Panel Bibliotekarza" : "Panel użytkownika";

    bool isFromList = Model.Id > 0;
    ViewData["Title"] = isFromList ? "Rejestracja egzemplarzy" : "Zarejestruj nową książkę";
}

@* --- POWIADOMIENIE TOAST --- *@
@if (TempData["SuccessMessage"] != null)
{
    <div id="successToast" class="toast-container-top-right">
        <div class="toast-alert">
            <div class="toast-check-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3"
                     stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
            </div>
            <div class="toast-message">
                Dodano książkę „@TempData["SuccessMessage"]”.
            </div>
        </div>
    </div>
}

<div class="management-panel-layout">
    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-icon-box">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E67E22" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    @if (isAdmin)
                    {
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                    }
                    else
                    {
                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                    }
                </svg>
            </div>
            <div class="sidebar-titles">
                <h3 class="sidebar-title">@sidebarTitle</h3>
                <p class="sidebar-subtitle">Zarządzanie księgozbiorem Biblioteka Nova</p>
            </div>
        </div>
        <nav class="sidebar-nav">
            <a asp-controller="Ksiazki" asp-action="Lista" class="sidebar-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;">
                    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                    <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                </svg>
                Lista książek
            </a>

            @if (isLibrarian)
            {
                <a asp-controller="Ksiazki" asp-action="Zarejestruj" class="sidebar-link active">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        <polyline points="14 2 14 8 20 8"></polyline>
                    </svg>
                    Zarejestruj książkę
                </a>
            }

            @if (isManager)
            {
                <a href="/Manager/Rejestracje" class="sidebar-link">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="3" y1="9" x2="21" y2="9"></line>
                        <line x1="9" y1="21" x2="9" y2="9"></line>
                    </svg>
                    Lista rejestracji książek
                </a>
            }
            @if (isLibrarian)
            {
                <a asp-controller="Ksiazki" asp-action="RejestracjaWypozyczen" class="sidebar-link">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path>
                    </svg>
                    Rejestracja wypożyczeń
                </a>
                <a asp-controller="Ksiazki" asp-action="ListaWypozyczen"
                   class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "ListaWypozyczen" ? "active" : "")">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        <polyline points="14 2 14 8 20 8"></polyline>
                        <line x1="16" y1="13" x2="8" y2="13"></line>
                        <line x1="16" y1="17" x2="8" y2="17"></line>
                        <polyline points="10 9 9 9 8 9"></polyline>
                    </svg>
                    Lista wypożyczeń
                </a>
            }
        </nav>
    </aside>

    <main class="management-content">
        <div class="form-container">
            <a asp-controller="Ksiazki" asp-action="Lista" class="back-link"
               style="margin-bottom: 20px; display: inline-flex; align-items: center; text-decoration: none; color: #666;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                     style="margin-right: 5px;">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Powrót
            </a>

            <div class="form-card">
                <header class="form-header">
                    <div class="form-icon-circle">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E67E22" stroke-width="2">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                            <line x1="12" y1="18" x2="12" y2="12"></line>
                            <line x1="9" y1="15" x2="15" y2="15"></line>
                        </svg>
                    </div>
                    <div class="form-title-group">
                        <h1 class="form-main-title">@(isFromList ? "Rejestracja z listy" : "Zarejestruj nową książkę")
                        </h1>
                        <p class="form-subtitle">@(isFromList ? "Wypełniasz dane dla kolejnych egzemplarzy istniejącej pozycji." : "Wypełnij formularz, aby dodać książkę do katalogu biblioteki.")</p>
                    </div>
                </header>

                <form class="book-registration-form" method="post" asp-action="Zarejestruj">
                    <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 15px;"></div>

                    <input type="hidden" asp-for="Id" />

                    <div class="form-row grid-2">
                        <div class="input-group">
                            <label>Autorzy książki</label>
                            <input asp-for="Autor" placeholder="np. Andrzej Sapkowski" readonly="@isFromList"
                                   style="@(isFromList ? "background-color: #f9f9f9; color: #777;" : "")">
                            <span asp-validation-for="Autor" class="text-danger" style="font-size: 12px;"></span>
                        </div>
                        <div class="input-group">
                            <label>Tytuł książki</label>
                            <input asp-for="Tytul" placeholder="np. Wiedźmin" readonly="@isFromList"
                                   style="@(isFromList ? "background-color: #f9f9f9; color: #777;" : "")">
                            <span asp-validation-for="Tytul" class="text-danger" style="font-size: 12px;"></span>
                        </div>
                    </div>

                    <div class="form-row grid-1">
                        <div class="input-group">
                            <label>Gatunek</label>
                            @if (isFromList)
                            {
                                <input type="text" value="@Model.Gatunek" readonly
                                       style="background-color: #f9f9f9; color: #777; width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;">
                                <input type="hidden" asp-for="Gatunek" />
                            }
                            else
                            {
                                <select asp-for="Gatunek" asp-items="ViewBag.Gatunki"
                                        style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;">
                                    <option value="">-- Wybierz gatunek --</option>
                                </select>
                            }
                            <span asp-validation-for="Gatunek" class="text-danger" style="font-size: 12px;"></span>
                        </div>
                    </div>

                    <div class="form-row grid-3">
                        <div class="input-group">
                            <label>Liczba stron</label>
                            <input asp-for="LiczbaStron" type="number">
                            <span asp-validation-for="LiczbaStron" class="text-danger" style="font-size: 12px;"></span>
                        </div>
                        <div class="input-group">
                            <label>Rok wydania</label>
                            <input asp-for="RokWydania" type="number">
                            <span asp-validation-for="RokWydania" class="text-danger" style="font-size: 12px;"></span>
                        </div>
                        <div class="input-group">
                            <label>Cena (PLN)</label>
                            @* ZMIANA: Usunięto oninput i inputmode, dodano atrybut data-val-number z dokładną treścią
                            testu *@
                            <input type="text" asp-for="Cena" name="Cena"
                                   value="@(Model.Cena.HasValue ? Model.Cena.Value.ToString("0.00").Replace(".", ",") : "")"
                                   class="form-control" placeholder="0,00"
                                   data-val-number="Pole Cena książki może zawierać tylko cyfry">
                            <span asp-validation-for="Cena" class="text-danger" style="font-size: 12px;"></span>
                        </div>
                    </div>

                    <div class="form-row grid-2">
                        <div class="input-group">
                            <label>Wydawnictwo</label>
                            <input asp-for="Wydawnictwo">
                            <span asp-validation-for="Wydawnictwo" class="text-danger" style="font-size: 12px;"></span>
                        </div>
                        <div class="input-group">
                            <label>Liczba rejestrowanych sztuk</label>
                            <input asp-for="LiczbaSztuk" type="number">
                            <span asp-validation-for="LiczbaSztuk" class="text-danger" style="font-size: 12px;"></span>
                        </div>
                    </div>

                    <div class="form-row grid-1">
                        <div class="input-group">
                            <label>Opis książki</label>
                            <textarea asp-for="Opis" rows="4" placeholder="Krótki opis książki..."></textarea>
                            <span asp-validation-for="Opis" class="text-danger" style="font-size: 12px;"></span>
                        </div>
                    </div>

                    <div class="form-footer">
                        <button type="button" class="btn-cancel" onclick="history.back()">Anuluj</button>
                        <button type="submit" class="btn-submit-orange">Dodaj książkę</button>
                    </div>
                </form>
            </div>
        </div>
    </main>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function () {
            // Przekazanie informacji o sukcesie z C# do JS w sposób bezpieczny dla parsera
            var isSuccess = "@(TempData["SuccessMessage"] != null ? "true" : "false")" === "true";

            if (isSuccess) {
                setTimeout(function () {
                    var toast = document.getElementById("successToast");
                    if (toast) {
                        toast.style.opacity = "0";
                        toast.style.transform = "translateX(30px)";
                        setTimeout(function () { toast.remove(); }, 500);
                    }
                }, 5000);
            }

            if ($.validator) {
                // 1. Nadpisujemy domyślne komunikaty walidacji
                $.extend($.validator.messages, {
                    number: "Pole może zawierać tylko cyfry i separator (przecinek)",
                    digits: "Pole może zawierać tylko cyfry",
                    range: $.validator.format("Wprowadź wartość z zakresu od {0} do {1}.")
                });

                // 2. Naprawa walidacji liczbowej dla separatorów pl-PL
                $.validator.methods.number = function (value, element) {
                    return this.optional(element) ||
                        /^-?(?:\d+|\d{1,3}(?:[\s\.]\d{3})+)(?:[\,]\d+)?$/.test(value) ||
                        /^-?(?:\d+|\d{1,3}(?:[\s\,]\d{3})+)(?:[\.]\d+)?$/.test(value);
                };

                // 3. Naprawa walidacji zakresu (Range) dla polskich liczb
                $.validator.methods.range = function (value, element, param) {
                    var globalizedValue = value.replace(",", ".");
                    return this.optional(element) || (parseFloat(globalizedValue) >= param[0] && parseFloat(globalizedValue) <= param[1]);
                };
            }
        });
    </script>
}