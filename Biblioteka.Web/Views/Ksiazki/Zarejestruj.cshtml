@using System.Security.Claims
@{
    bool isAdmin = User.IsInRole("Administrator");
    bool isLibrarian = User.IsInRole("Bibliotekarz");
    string sidebarTitle = isAdmin ? "Panel administratora" : "Panel bibliotekarza";
    ViewData["Title"] = "Zarejestruj książkę";
}

<div class="management-panel-layout">
    @* --- SIDEBAR --- *@
    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-icon-box">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E67E22" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    @if (isAdmin) { <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path> }
                    else { <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path> }
                </svg>
            </div>
            <div class="sidebar-titles">
                <h3 class="sidebar-title">@sidebarTitle</h3>
                <p class="sidebar-subtitle">Zarządzanie księgozbiorem Biblioteka Nova</p>
            </div>
        </div>
        <nav class="sidebar-nav">
            <a asp-controller="Ksiazki" asp-action="Lista" class="sidebar-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
                Lista książek
            </a>
            <a asp-controller="Ksiazki" asp-action="Zarejestruj" class="sidebar-link active">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line><rect x="3" y="3" width="18" height="18" rx="2"></rect></svg>
                Zarejestruj książkę
            </a>
        </nav>
    </aside>

    @* --- GŁÓWNA TREŚĆ --- *@
    <main class="management-content">
        <div class="form-container">
            @* Powrót *@
            <a asp-controller="Ksiazki" asp-action="Lista" class="back-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                Powrót
            </a>

            @* Karta Formularza *@
            <div class="form-card">
                <header class="form-header">
                    <div class="form-icon-circle">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E67E22" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="12" y1="18" x2="12" y2="12"></line><line x1="9" y1="15" x2="15" y2="15"></line></svg>
                    </div>
                    <div class="form-title-group">
                        <h1 class="form-main-title">Zarejestruj nową książkę</h1>
                        <p class="form-subtitle">Wypełnij formularz, aby dodać książkę do katalogu biblioteki.</p>
                    </div>
                </header>

                <form class="book-registration-form">
                    @* Rząd 1: Autor i Tytuł *@
                    <div class="form-row grid-2">
                        <div class="input-group">
                            <label>Autorzy książki</label>
                            <input type="text" placeholder="np. Andrzej Sapkowski">
                        </div>
                        <div class="input-group">
                            <label>Tytuł książki</label>
                            <input type="text" placeholder="np. Wiedźmin">
                        </div>
                    </div>

                    @* Rząd 2: Gatunek *@
                    <div class="form-row grid-1">
                        <div class="input-group">
                            <label>Gatunek</label>
                            <input type="text" placeholder="Fantastyka">
                        </div>
                    </div>

                    @* Rząd 3: Strony, Rok, Cena *@
                    <div class="form-row grid-3">
                        <div class="input-group">
                            <label>Liczba stron</label>
                            <input type="number">
                        </div>
                        <div class="input-group">
                            <label>Rok wydania</label>
                            <input type="number">
                        </div>
                        <div class="input-group">
                            <label>Cena książki (PLN)</label>
                            <input type="text">
                        </div>
                    </div>

                    @* Rząd 4: Wydawnictwo i Sztuki *@
                    <div class="form-row grid-2">
                        <div class="input-group">
                            <label>Wydawnictwo</label>
                            <input type="text">
                        </div>
                        <div class="input-group">
                            <label>Liczba zarejestrowanych sztuk</label>
                            <input type="number">
                        </div>
                    </div>

                    @* Rząd 5: Opis *@
                    <div class="form-row grid-1">
                        <div class="input-group">
                            <label>Opis</label>
                            <textarea rows="4" placeholder="Krótki opis książki..."></textarea>
                        </div>
                    </div>

                    @* Stopka przycisków *@
                    <div class="form-footer">
                        <button type="button" class="btn-cancel" onclick="history.back()">Anuluj</button>
                        <button type="submit" class="btn-submit-orange">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                            Dodaj książkę
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </main>
</div>