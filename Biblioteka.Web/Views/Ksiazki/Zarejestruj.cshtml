@using System.Security.Claims
@{
    bool isAdmin = User.IsInRole("Administrator");
    bool isLibrarian = User.IsInRole("Bibliotekarz");
    string sidebarTitle = isAdmin ? "Panel administratora" : "Panel bibliotekarza";
    ViewData["Title"] = "Zarejestruj książkę";
}

@* --- WYŁĄCZNIE PŁYWAJĄCY TOAST --- *@
@if (TempData["SuccessMessage"] != null)
{
    <div id="successToast" class="toast-container-top-right">
        <div class="toast-alert">
            <div class="toast-check-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
            </div>
            <div class="toast-message">
                Dodano książkę „@TempData["SuccessMessage"]”.
            </div>
        </div>
    </div>

    <script>
        setTimeout(function () {
            var toast = document.getElementById('successToast');
            if (toast) {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(30px)';
                setTimeout(function() { toast.remove(); }, 500);
            }
        }, 5000);
    </script>
}

<div class="management-panel-layout">
    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-icon-box">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E67E22" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    @if (isAdmin) { <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path> }
                    else { <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path> }
                </svg>
            </div>
            <div class="sidebar-titles">
                <h3 class="sidebar-title">@sidebarTitle</h3>
                <p class="sidebar-subtitle">Zarządzanie księgozbiorem Biblioteka Nova</p>
            </div>
        </div>
        <nav class="sidebar-nav">
            <a asp-controller="Ksiazki" asp-action="Lista" class="sidebar-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
                Lista książek
            </a>
            <a asp-controller="Ksiazki" asp-action="Zarejestruj" class="sidebar-link active">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line><rect x="3" y="3" width="18" height="18" rx="2"></rect></svg>
                Zarejestruj książkę
            </a>
        </nav>
    </aside>

    <main class="management-content">
        <div class="form-container">
            <a asp-controller="Ksiazki" asp-action="Lista" class="back-link" style="margin-bottom: 20px; display: inline-flex; align-items: center; text-decoration: none; color: #666;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 5px;"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                Powrót
            </a>

            <div class="form-card">
                <header class="form-header">
                    <div class="form-icon-circle">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E67E22" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="12" y1="18" x2="12" y2="12"></line><line x1="9" y1="15" x2="15" y2="15"></line></svg>
                    </div>
                    <div class="form-title-group">
                        <h1 class="form-main-title">Zarejestruj nową książkę</h1>
                        <p class="form-subtitle">Wypełnij formularz, aby dodać książkę do katalogu biblioteki.</p>
                    </div>
                </header>

                <form class="book-registration-form" method="post" asp-action="Zarejestruj">
                    <div class="form-row grid-2">
                        <div class="input-group">
                            <label>Autorzy książki</label>
                            <input type="text" name="Autor" placeholder="np. Andrzej Sapkowski" required>
                        </div>
                        <div class="input-group">
                            <label>Tytuł książki</label>
                            <input type="text" name="Tytul" placeholder="np. Wiedźmin" required>
                        </div>
                    </div>
                    <div class="form-row grid-1">
                        <div class="input-group">
                            <label>Gatunek</label>
                            <input type="text" name="Gatunek" placeholder="Fantastyka" required>
                        </div>
                    </div>
                    <div class="form-row grid-3">
                        <div class="input-group"><label>Liczba stron</label><input type="number" name="LiczbaStron" required></div>
                        <div class="input-group"><label>Rok wydania</label><input type="number" name="RokWydania" required></div>
                        <div class="input-group"><label>Cena (PLN)</label><input type="text" name="Cena" required></div>
                    </div>
                    <div class="form-row grid-2">
                        <div class="input-group"><label>Wydawnictwo</label><input type="text" name="Wydawnictwo" required></div>
                        <div class="input-group"><label>Sztuki</label><input type="number" name="Ilosc" required></div>
                    </div>
                    <div class="form-row grid-1">
                        <div class="input-group"><label>Opis</label><textarea rows="4" name="Opis" placeholder="Krótki opis książki..."></textarea></div>
                    </div>
                    <div class="form-footer">
                        <button type="button" class="btn-cancel" onclick="history.back()">Anuluj</button>
                        <button type="submit" class="btn-submit-orange">Dodaj książkę</button>
                    </div>
                </form>
            </div>
        </div>
    </main>
</div>