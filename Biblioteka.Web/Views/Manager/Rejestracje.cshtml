@{
    ViewData["Title"] = "Lista rejestracji książek";
    string sidebarTitle = "Panel managera";
}

<div class="management-panel-layout">
    @* --- PASEK BOCZNY (Tylko jedna zakładka) --- *@
    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-icon-box">
                @* Ikona teczki dla Managera *@
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E67E22" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
            </div>
            <div class="sidebar-titles">
                <h3 class="sidebar-title">@sidebarTitle</h3>
                <p class="sidebar-subtitle">Zarządzanie systemem biblioteka Nova</p>
            </div>
        </div>

        <nav class="sidebar-nav">
            @* Zostawiamy tylko to: *@
            <a href="/Manager/Rejestracje" class="sidebar-link active">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="3" y1="9" x2="21" y2="9"></line>
                    <line x1="9" y1="21" x2="9" y2="9"></line>
                </svg>
                Lista rejestracji książek
            </a>
        </nav>
    </aside>

    @* --- TREŚĆ Z LISTĄ --- *@
    <main class="management-content">
        <div class="catalog-container">
            <header class="catalog-header">
                <h1 class="catalog-main-title">Lista rejestracji książek</h1>
                <p class="catalog-subtitle">Przegląd wszystkich rejestracji książek dokonanych przez bibliotekarzy.</p>
            </header>

            <div class="registration-table-wrapper">
                <div class="reg-table-header">
                    <div class="col-reg-main">Tytuł i Autor</div>
                    <div class="col-reg-info">Gatunek</div>
                    <div class="col-reg-info">Wydawnictwo</div>
                    <div class="col-reg-date">Data rejestracji</div>
                    <div class="col-reg-user">Zarejestrował(a)</div>
                </div>

                <div class="reg-table-body">
                    @* Tutaj trafi Twoja pętla @foreach z danymi z bazy *@
                    <div class="reg-item-row">
                        <div class="col-reg-main">
                            <div class="reg-book-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3498db" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg></div>
                            <div class="reg-text">
                                <span class="reg-title">Przykładowa Książka</span>
                                <span class="reg-author">Jan Kowalski</span>
                            </div>
                        </div>
                        <div class="col-reg-info">Literatura</div>
                        <div class="col-reg-info">PWN</div>
                        <div class="col-reg-date">2026-04-30</div>
                        <div class="col-reg-user">Anna Bibliotekarz</div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>