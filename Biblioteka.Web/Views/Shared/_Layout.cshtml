<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Biblioteka Nova</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Lora:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/@@phosphor-icons/web"></script>
    <link rel="stylesheet" href="~/css/style.css"> @* Poprawiona ścieżka do CSS *@
</head>
<body>
    <header class="navbar">
        <div class="logo">
            <i class="ph ph-book-open"></i>
            <span>Biblioteka Nova</span>
        </div>
        <nav class="nav-links">
            <a asp-controller="Home" asp-action="Index" class="active">Strona Główna</a>
            <a asp-controller="Ksiazki" asp-action="Index"><i class="ph ph-books"></i> Książki</a>
        </nav>
        <div class="nav-actions">
            <a asp-controller="Account" asp-action="Login"><i class="ph ph-sign-in"></i> Logowanie</a>
            <a asp-controller="Uzytkownicy" asp-action="Dodaj"><i class="ph ph-user-plus"></i> Rejestracja</a>
        </div>
    </header>

    @RenderBody() @* Tu wskoczy zawartość konkretnych stron *@

    <footer class="text-center mt-4">
        <p>&copy; 2026 - Biblioteka Nova</p>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>