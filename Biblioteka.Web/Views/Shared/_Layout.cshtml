<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Biblioteka Nova</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar-custom">
            <a asp-controller="Home" asp-action="Index" class="brand-logo">
                <i class="fa-solid fa-book-open" style="margin-right:8px; color:#8B4513;"></i> Biblioteka Nova
            </a>

            <div class="nav-links">
                @{
                    // Sprawdzamy, w którym kontrolerze (sekcji) aktualnie się znajdujemy
                    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                }

                @if (currentController == "Uzytkownicy")
                {
                    // WIDOK DLA ZALOGOWANEGO (Tylko w Panelu Administratora)
                    <a asp-controller="Home" asp-action="Index" style="color: #555;">Strona Główna</a>

                    <a asp-controller="Uzytkownicy" asp-action="Dashboard" class="active-nav-link"
                           style="display: flex; align-items: center; gap: 6px;">
                        <i class="fa-regular fa-user"></i> Konto
                    </a>

                    <a asp-controller="Account" asp-action="Logout"
                           style="color: #666; display: flex; align-items: center; gap: 6px;">
                        <i class="fa-solid fa-arrow-right-from-bracket"></i> Wyloguj
                    </a>
                }
                else
                {
                    // WIDOK DLA GOŚCIA (Strona Główna, Ekran Logowania itp.)
                    <a asp-controller="Home" asp-action="Index"
                           class="@(currentController == "Home" ? "active-nav-link" : "")" style="color: #555;">Strona
                        Główna</a>
                        <a asp-controller="Account" asp-action="Login"
                               style="color: #555; display: flex; align-items: center; gap: 6px;">
                            <i class="fa-solid fa-arrow-right-to-bracket"></i> Logowanie
                        </a>

                        <a asp-controller="Account" asp-action="Register"
                               style="color: #555; display: flex; align-items: center; gap: 6px;">
                            <i class="fa-solid fa-user-plus"></i> Rejestracja
                        </a>
                    }
                </div>
            </nav>
        </header>

        <main role="main">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success"
                     style="padding: 15px; background-color: #d4edda; color: #155724; border: 1px solid #c3e6cb; margin: 10px 20px; border-radius: 5px;">
                    <i class="fa-solid fa-check-circle"></i> @TempData["SuccessMessage"]
                </div>
            }
            @RenderBody()
        </main>

        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        @await RenderSectionAsync("Scripts", required: false)
    </body>

</html>