@model List<Biblioteka.Web.Models.UprawnienieItemViewModel>

@{
    ViewData["Title"] = "Uprawnienia";
}

<div class="admin-wrapper">
    @* --- BOCZNY PASEK NAWIGACJI --- *@
    <aside class="sidebar">
        <div class="sidebar-header">
            <h3 class="sidebar-title">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E67E22" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
                Panel Admina
            </h3>
            <p class="sidebar-subtitle">Zarządzanie systemem Biblioteka Nova</p>
        </div>

        <nav class="sidebar-nav">
            <a href="/Uzytkownicy/Index" class="sidebar-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                </svg>
                Klienci / Wyszukiwanie
            </a>
            <a href="/Uzytkownicy/Dodaj" class="sidebar-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="8.5" cy="7" r="4"></circle>
                    <line x1="20" y1="8" x2="20" y2="14"></line>
                    <line x1="23" y1="11" x2="17" y2="11"></line>
                </svg>
                Dodaj użytkownika
            </a>
            <a href="/Uprawnienia/Index" class="sidebar-link active">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path>
                </svg>
                Lista uprawnień
            </a>
        </nav>
    </aside>

    @* --- GŁÓWNA TREŚĆ --- *@
    <main class="admin-content">
        <div class="permissions-container">
            
            <div class="page-header" style="margin-bottom: 2rem;">
                <h1 class="page-title">Uprawnienia</h1>
                <p class="page-description">Przeglądaj role i użytkowników, którzy je posiadają.</p>
            </div>

            @* Złączona lista (gap: 0 w CSS) *@
            <div class="permissions-list">
                @foreach (var item in Model)
                {
                    <div class="permission-card">
                        <div class="permission-badge-container">
                            <span class="permission-badge @item.BadgeClass">@item.Nazwa</span>
                        </div>
                        
                        <div class="permission-info">
                            <span class="permission-title">@item.Opis</span>
                            <span class="permission-count">@item.LiczbaUzytkownikow użytkowników</span>
                        </div>

                        <div class="permission-action">
                            <a href="/Uprawnienia/Szczegoly?id=@item.Id" class="btn-show-users">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                    <circle cx="12" cy="12" r="3"></circle>
                                </svg>
                                Wyświetl użytkowników
                            </a>
                        </div>
                    </div>
                }
            </div>
            
        </div>
    </main>
</div>