@model Biblioteka.Web.Models.UprawnienieSzczegolyViewModel

@{
    ViewData["Title"] = "Szczegóły uprawnienia";
    
    // Pobieramy nazwę roli i zamieniamy na wielkie litery dla pewności porównania
    string roleName = Model.NazwaUprawnienia?.ToUpper() ?? "";
    
    // Logika przypisywania kolorów i opisów
    string badgeClass = "badge-select"; // Domyślnie Klient (niebieski)
    string description = "";

    if (roleName.Contains("ADMINISTRATOR"))
    {
        badgeClass = "badge-all"; // Pomarańczowy
        description = "Pełny dostęp do zarządzania systemem, bazą danych i uprawnieniami użytkowników.";
    }
    else if (roleName.Contains("BIBLIOTEKARZ"))
    {
        badgeClass = "badge-insert"; // Zielony
        description = "Zarządzanie księgozbiorem, obsługą wypożyczeń, zwrotów oraz katalogowaniem pozycji.";
    }
    else if (roleName.Contains("MANAGER"))
    {
        badgeClass = "badge-alter"; // Fioletowy
        description = "Dostęp do statystyk, raportów finansowych i zarządzania kadrą biblioteczną.";
    }
    else if (roleName.Contains("KLIENT"))
    {
        badgeClass = "badge-select"; // Niebieski
        description = "Podstawowy dostęp: przeglądanie katalogu, rezerwacje online i zarządzanie własnym profilem.";
    }
}

<div class="admin-wrapper">
    @* --- BOCZNY PASEK NAWIGACJI --- *@
    <aside class="sidebar">
        <div class="sidebar-header">
            <h3 class="sidebar-title">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E67E22" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
                Panel Admina
            </h3>
            <p class="sidebar-subtitle">Zarządzanie systemem Biblioteka Nova</p>
        </div>

        <nav class="sidebar-nav">
            <a href="/Uzytkownicy/Index" class="sidebar-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                </svg>
                Klienci / Wyszukiwanie
            </a>
            <a href="/Uzytkownicy/Dodaj" class="sidebar-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="8.5" cy="7" r="4"></circle>
                    <line x1="20" y1="8" x2="20" y2="14"></line>
                    <line x1="23" y1="11" x2="17" y2="11"></line>
                </svg>
                Dodaj użytkownika
            </a>
            <a href="/Uprawnienia/Index" class="sidebar-link active">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path
                        d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4">
                    </path>
                </svg>
                Lista uprawnień
            </a>
        </nav>
    </aside>

    @* --- GŁÓWNA TREŚĆ --- *@
    <main class="admin-content">
        <div class="permissions-container">
            
            <a href="/Uprawnienia/Index" class="back-link"
                   style="margin-bottom: 2rem; display: inline-flex; align-items: center; gap: 8px; color: #64748b; text-decoration: none; font-weight: 600;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Powrót do listy uprawnień
            </a>

            @* NAGŁÓWEK Z ODPOWIEDNIM KOLOREM *@
            <div class="permission-detail-header"
                 style="display: flex; align-items: center; gap: 20px; margin-top: 20px; margin-bottom: 30px;">
                <span class="permission-badge @badgeClass"
                      style="font-size: 0.85rem; padding: 8px 20px;">@roleName</span>
                <span class="permission-detail-desc" style="color: #64748b; font-size: 1rem;">@description</span>
            </div>

            @* --- KROK 1: MIEJSCE NA KOMUNIKAT (ALERT) --- *@
            @if (ViewData["Message"] != null)
            {
                <div class="alert alert-info"
                     style="margin-bottom: 20px; padding: 15px; background-color: #e0f2fe; border: 1px solid #bae6fd; border-radius: 8px; color: #0369a1; display: flex; align-items: center; gap: 10px;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="12" y1="16" x2="12" y2="12"></line>
                        <line x1="12" y1="8" x2="12.01" y2="8"></line>
                    </svg>
                    <span>@ViewData["Message"]</span>
                </div>
            }

            <div class="table-container-simple"
                 style="background: white; border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden;">
                @if (Model.Uzytkownicy != null && Model.Uzytkownicy.Any())
                {
                    <table class="table-simple" style="width: 100%; border-collapse: collapse;">
                        <thead style="background: #f8fafc; border-bottom: 1px solid #e2e8f0;">
                            <tr>
                                <th style="text-align: left; padding: 15px 20px; color: #475569; font-weight: 600;">Login
                                </th>
                                <th style="text-align: left; padding: 15px 20px; color: #475569; font-weight: 600;">Imię i
                                    nazwisko</th>
                                    <th style="text-align: left; padding: 15px 20px; color: #475569; font-weight: 600;">Rola
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in Model.Uzytkownicy)
                                {
                                    <tr style="border-bottom: 1px solid #f1f5f9;">
                                        <td style="padding: 15px 20px; font-family: monospace; color: #1e293b;">@user.Login</td>
                                        <td style="padding: 15px 20px; color: #1e293b;">@user.ImieNazwisko</td>
                                        <td style="padding: 15px 20px; color: #64748b;">@user.Rola</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                else
                    {
                        @* --- KROK 2: DYNAMICZNY EMPTY STATE DLA TC_U12 --- *@
                        <div class="empty-state-container" style="padding: 60px 40px; text-align: center; color: #64748b;">
                            <div
                                style="background: #f1f5f9; width: 64px; height: 64px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
                                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2"
                                     stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="9" cy="7" r="4"></circle>
                                    <line x1="17" y1="8" x2="22" y2="13"></line>
                                    <line x1="22" y1="8" x2="17" y2="13"></line>
                                </svg>
                            </div>
                            @* Zmieniono na dynamiczny komunikat z ViewData dla testu TC_U12 *@
                            <h3 style="font-size: 1.1rem; font-weight: 600; color: #1e293b; margin-bottom: 0;">
                                @(ViewData["Message"] ?? "Brak użytkowników o wybranym uprawnieniu")
                            </h3>
                        </div>
                    }
                </div>

            </div>
        </main>
    </div>