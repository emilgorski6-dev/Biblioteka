@{
    ViewData["Title"] = "Panel Admina";
}

<div class="admin-wrapper">
    <aside class="sidebar">
        <div class="sidebar-header">
            <h3>
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E67E22" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 10px;">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
                Panel Admina
            </h3>
            <p>Zarządzanie systemem Biblioteka Nova</p>
        </div>

        <nav class="sidebar-nav">
            <a href="/Uzytkownicy/Index" class="sidebar-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                </svg>
                Klienci / Wyszukiwanie
            </a>
            
            <a href="/Uzytkownicy/Dodaj" class="sidebar-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="8.5" cy="7" r="4"></circle>
                    <line x1="20" y1="8" x2="20" y2="14"></line>
                    <line x1="23" y1="11" x2="17" y2="11"></line>
                </svg>
                Dodaj użytkownika
            </a>
        </nav>
    </aside>

    <main class="admin-content">
        <div class="welcome-screen">
            <div class="shield-icon">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#D35400" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
            </div>
            <h2>Witaj w Panelu Administratora</h2>
            <p>Wybierz zakładkę z menu po lewej stronie, aby rozpocząć pracę.</p>
        </div>
    </main>
</div>