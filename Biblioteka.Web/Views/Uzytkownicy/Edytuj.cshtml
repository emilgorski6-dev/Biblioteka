@model Biblioteka.Web.Models.EdytujUzytkownikaViewModel

@{
    ViewData["Title"] = "Edytuj użytkownika";
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="toast-container">
        <div class="toast">
            <div class="toast-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="12" y1="8" x2="12" y2="12"></line>
                    <line x1="12" y1="16" x2="12.01" y2="16"></line>
                </svg>
            </div>
            <div class="toast-content">
                <div asp-validation-summary="All"></div>
            </div>
        </div>
    </div>
}

<div class="profile-wrapper">
    <div class="back-link-container">
        <a href="/Uzytkownicy/Szczegoly?login=@Model.Login" class="back-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Wróć do szczegółów klienta
        </a>
    </div>

    <div class="page-header" style="margin-top: 20px;">
        <h1 class="page-title">Edytuj dane użytkownika</h1>
        <p class="page-description">Wprowadź poprawki do formularza. Zmiana loginu, e-maila oraz PESEL-u będzie sprawdzana pod kątem duplikatów w bazie.</p>
    </div>

    <div class="form-card">
        <form asp-action="Edytuj" method="post" novalidate>
            <input type="hidden" asp-for="Id" />
            
            <div class="form-section-title">Dane konta</div>
            <div class="form-group-full mb-3">
                <label class="form-label">Identyfikator (Login) *</label>
                <input asp-for="Login" class="form-input" />
            </div>

            <div class="form-row mb-3">
                <div>
                    <label class="form-label">Adres e-mail *</label>
                    <input asp-for="Email" type="email" class="form-input" />
                </div>
                <div>
                    <label class="form-label">Numer telefonu *</label>
                    <input asp-for="Telefon" class="form-input" maxlength="9" />
                </div>
            </div>

            <div class="form-section-title">Dane osobowe</div>
            <div class="form-row mb-3">
                <div>
                    <label class="form-label">Imię *</label>
                    <input asp-for="Imie" class="form-input" />
                </div>
                <div>
                    <label class="form-label">Nazwisko *</label>
                    <input asp-for="Nazwisko" class="form-input" />
                </div>
            </div>

            <div class="form-row mb-3">
                <div>
                    <label class="form-label">Numer PESEL *</label>
                    <input asp-for="Pesel" class="form-input" maxlength="11" />
                </div>
                <div>
                    <label class="form-label">Data urodzenia *</label>
                    <input asp-for="DataUrodzenia" type="date" class="form-input" />
                </div>
            </div>

            <div class="form-group-full mb-3">
                <label class="form-label">Płeć *</label>
                <select asp-for="Plec" class="form-select">
                    <option value="">-- wybierz --</option>
                    <option value="kobieta">Kobieta</option>
                    <option value="mężczyzna">Mężczyzna</option>
                </select>
            </div>

            <div class="form-section-title">Adres zamieszkania</div>
            <div class="form-row mb-3">
                <div>
                    <label class="form-label">Miejscowość *</label>
                    <input asp-for="Miejscowosc" class="form-input" />
                </div>
                <div>
                    <label class="form-label">Kod pocztowy *</label>
                    <input asp-for="KodPocztowy" class="form-input" />
                </div>
            </div>

            <div class="form-row mb-3">
                <div style="flex: 2;">
                    <label class="form-label">Ulica (opcjonalnie)</label>
                    <input asp-for="Ulica" class="form-input" />
                </div>
                <div>
                    <label class="form-label">Nr posesji *</label>
                    <input asp-for="NumerPosesji" class="form-input" />
                </div>
                <div>
                    <label class="form-label">Nr lokalu (opcjonalnie)</label>
                    <input asp-for="NumerLokalu" class="form-input" />
                </div>
            </div>

            <div class="form-actions mt-4">
                <a href="/Uzytkownicy/Szczegoly?login=@Model.Login" class="btn-cancel"
                   style="border: none; cursor: pointer; text-align: center; display: flex; align-items: center; justify-content: center; font: inherit; text-decoration: none;">
                    Anuluj edycję
                </a>

                <button type="submit" class="btn-submit">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;">
                        <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
                        <polyline points="17 21 17 13 7 13 7 21"></polyline>
                        <polyline points="7 3 7 8 15 8"></polyline>
                    </svg>
                    Zapisz zmiany
                </button>
            </div>
        </form>
    </div>
</div>