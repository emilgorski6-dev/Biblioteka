@model List<Biblioteka.Web.Models.UzytkownikListItemViewModel>

@{
    ViewData["Title"] = "Klienci Biblioteki";
}

<div class="admin-wrapper">
    <aside class="sidebar">
        <div class="sidebar-header">
            <h3 class="sidebar-title">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E67E22" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
                Panel Admina
            </h3>
            <p class="sidebar-subtitle">Zarządzanie systemem Biblioteka Nova</p>
        </div>

        <nav class="sidebar-nav">
            <a href="/Uzytkownicy/Index" class="sidebar-link active">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                    <line x1="17" y1="8" x2="23" y2="8"></line>
                    <line x1="17" y1="12" x2="23" y2="12"></line>
                    <line x1="17" y1="16" x2="23" y2="16"></line>
                </svg>
                Klienci / Wyszukiwanie
            </a>
            <a href="/Uzytkownicy/Dodaj" class="sidebar-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="8.5" cy="7" r="4"></circle>
                    <line x1="20" y1="8" x2="20" y2="14"></line>
                    <line x1="23" y1="11" x2="17" y2="11"></line>
                </svg>
                Dodaj użytkownika
            </a>
        </nav>
    </aside>

    <main class="admin-content">
        
        <div class="page-header">
            <h1 class="page-title">Klienci Biblioteki</h1>
            <p class="page-description">Przeszukuj listę użytkowników. W zakładce zablokowanych możesz zarządzać kontami wymagającymi interwencji administratora.</p>
        </div>

        <div class="tab-container">
            <a href="/Uzytkownicy/Index" class="tab-link active">Lista aktywnych klientów</a>
            <a href="/Uzytkownicy/Zapomniani" class="tab-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
                Zablokowani użytkownicy
            </a>
        </div>

        <div class="search-card">
            <div class="search-input-wrapper">
                <svg class="search-icon-svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <input type="text" class="search-input" placeholder="Szukaj po: login, imię i nazwisko, PESEL...">
            </div>
        </div>

        <div class="table-card">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Login</th>
                        <th>Imię</th>
                        <th>Nazwisko</th>
                        <th>Adres e-mail</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="td-login">@user.Login</td>
                        <td>@user.Imie</td>
                        <td>@user.Nazwisko</td>
                        <td>@user.Email</td>
                        <td>
                            <span class="status-badge status-active">
                                @user.Status
                            </span>
                        </td>
                        <td class="td-action">
                            <a asp-controller="Uzytkownicy"
                            asp-action="Szczegoly"
                            asp-route-login="@user.Login"
                            class="link-profile">
                            Zobacz profil
                            </a>
                        </td>
                    </tr>
                }
                </tbody>        
            </table>
        </div>

    </main>
</div>