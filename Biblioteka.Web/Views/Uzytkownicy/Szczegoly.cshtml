@model Biblioteka.Web.Data.Entities.Uzytkownik

@{
    ViewData["Title"] = "Profil użytkownika";
}

<div class="profile-wrapper">
    <div class="back-link-container">
        <a href="/Uzytkownicy/Index" class="back-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Wróć do listy klientów
        </a>
    </div>

    <div class="profile-header-main">
        <div class="profile-avatar-large">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#E67E22" stroke-width="1.5">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
            </svg>
        </div>

        <div class="profile-info-basic">
            <div class="name-row">
                <h1>@Model.Imie @Model.Nazwisko</h1>
                <span class="status-pill @(Model.CzyZablokowany ? "status-locked" : "status-active")">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2.5">
                        <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                    Status: @(Model.CzyZablokowany ? "Zablokowany" : "Aktywny")
                </span>
            </div>
            <div class="card-id-badge">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="5" width="18" height="14" rx="2" ry="2"></rect>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                </svg>
                Karta: <span class="badge-text">@Model.Login.ToUpper()</span>
            </div>
        </div>

        <div class="profile-header-actions" style="display: flex; gap: 10px;">
            <a href="/Uzytkownicy/Edytuj?login=@Model.Login" class="btn-submit"
                   style="text-decoration: none; display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 10px 20px;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                </svg>
                Edytuj
            </a>

            <form asp-action="Zapomnij" asp-route-id="@Model.Id" method="post"
                  onsubmit="return confirm('Czy na pewno chcesz zapomnieć tego użytkownika? Operacja jest NIEODWRACALNA. Wszystkie uprawnienia zostaną usunięte.');"
                  style="display: inline;">

                <button type="submit" class="btn-zapomnij"
                        style="background: #1a1a1a; color: white; padding: 10px 18px; border-radius: 8px; border: none; cursor: pointer; display: inline-flex; align-items: center; gap: 10px; font-family: inherit;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                        <line x1="17" y1="8" x2="22" y2="13"></line>
                        <line x1="22" y1="8" x2="17" y2="13"></line>
                    </svg>
                    Zapomnij użytkownika
                </button>
            </form>
        </div>
    </div>

    <div class="details-container-card">
        <div class="card-header-title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E67E22" stroke-width="2">
                <rect x="3" y="4" width="18" height="16" rx="2"></rect>
                <circle cx="9" cy="10" r="2"></circle>
                <line x1="15" y1="8" x2="19" y2="8"></line>
                <line x1="15" y1="12" x2="19" y2="12"></line>
                <line x1="7" y1="16" x2="17" y2="16"></line>
            </svg>
            Dane klienta
        </div>

        <div class="details-grid">
            <div class="detail-item">
                <div class="item-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                    <circle cx="12" cy="7" r="4"></circle>
                </svg></div>
                <div class="item-content"><label>LOGIN</label><span>@Model.Login</span></div>
            </div>
            <div class="detail-item">
                <div class="item-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                </svg></div>
                <div class="item-content"><label>HASŁO</label><span>••••••••</span></div>
            </div>
            <div class="detail-item">
                <div class="item-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                    <circle cx="12" cy="7" r="4"></circle>
                </svg></div>
                <div class="item-content"><label>IMIĘ</label><span>@Model.Imie</span></div>
            </div>

            <div class="detail-item">
                <div class="item-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                    <circle cx="12" cy="7" r="4"></circle>
                </svg></div>
                <div class="item-content"><label>NAZWISKO</label><span>@Model.Nazwisko</span></div>
            </div>
            <div class="detail-item">
                <div class="item-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="16" rx="2"></rect>
                    <line x1="7" y1="8" x2="17" y2="8"></line>
                    <line x1="7" y1="12" x2="17" y2="12"></line>
                    <line x1="7" y1="16" x2="13" y2="16"></line>
                </svg></div>
                <div class="item-content"><label>PESEL</label><span>@Model.Pesel</span></div>
            </div>
            <div class="detail-item">
                <div class="item-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                </svg></div>
                <div class="item-content"><label>DATA
                    URODZENIA</label><span>@Model.DataUrodzenia.ToString("yyyy-MM-dd")</span></div>
                </div>

                <div class="detail-item">
                    <div class="item-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
                        <line x1="12" y1="17" x2="12.01" y2="17"></line>
                    </svg></div>
                    <div class="item-content"><label>PŁEĆ</label><span>@Model.Plec</span></div>
                </div>
                <div class="detail-item">
                    <div class="item-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                        <polyline points="22,6 12,13 2,6"></polyline>
                    </svg></div>
                    <div class="item-content"><label>E-MAIL</label><span>@Model.Email</span></div>
                </div>
                <div class="detail-item">
                    <div class="item-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path
                            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z">
                        </path>
                    </svg></div>
                    <div class="item-content"><label>NR TELEFONU</label><span>@Model.Telefon</span></div>
                </div>

                <div class="detail-item">
                    <div class="item-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                        <circle cx="12" cy="10" r="3"></circle>
                    </svg></div>
                    <div class="item-content"><label>MIEJSCOWOŚĆ</label><span>@Model.Miejscowosc</span></div>
                </div>
                <div class="detail-item">
                    <div class="item-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="3 6 5 6 21 6"></polyline>
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                    </svg></div>
                    <div class="item-content"><label>KOD POCZTOWY</label><span>@Model.KodPocztowy</span></div>
                </div>
                <div class="detail-item">
                    <div class="item-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                        <circle cx="12" cy="10" r="3"></circle>
                    </svg></div>
                    <div class="item-content"><label>ULICA</label><span>@Model.Ulica</span></div>
                </div>

                <div class="detail-item">
                    <div class="item-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                        <polyline points="9 22 9 12 15 12 15 22"></polyline>
                    </svg></div>
                    <div class="item-content"><label>NUMER POSESJI</label><span>@Model.NumerPosesji</span></div>
                </div>
                <div class="detail-item">
                    <div class="item-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                        <polyline points="9 22 9 12 15 12 15 22"></polyline>
                    </svg></div>
                    <div class="item-content"><label>NUMER LOKALU</label><span>@Model.NumerLokalu</span></div>
                </div>
            </div>
        </div>
    </div>