@{
    ViewData["Title"] = "Zablokowani Użytkownicy";
}

<div class="admin-wrapper">
    <aside class="sidebar">
        <div class="sidebar-header">
            <h3 class="sidebar-title">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E67E22" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
                Panel Admina
            </h3>
            <p class="sidebar-subtitle">Zarządzanie systemem Biblioteka Nova</p>
        </div>

        <nav class="sidebar-nav">
            <a href="/Uzytkownicy/Index" class="sidebar-link active">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                    <line x1="17" y1="8" x2="23" y2="8"></line>
                    <line x1="17" y1="12" x2="23" y2="12"></line>
                    <line x1="17" y1="16" x2="23" y2="16"></line>
                </svg>
                Klienci / Wyszukiwanie
            </a>
            <a href="/Uzytkownicy/Dodaj" class="sidebar-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="8.5" cy="7" r="4"></circle>
                    <line x1="20" y1="8" x2="20" y2="14"></line>
                    <line x1="23" y1="11" x2="17" y2="11"></line>
                </svg>
                Dodaj użytkownika
            </a>
        </nav>
    </aside>

    <main class="admin-content">
        
        <div class="page-header">
            <h1 class="page-title">Klienci Biblioteki</h1>
            <p class="page-description">Przeszukuj listę użytkowników. W zakładce zablokowanych możesz zarządzać kontami wymagającymi interwencji administratora.</p>
        </div>

        <div class="tab-container">
            <a href="/Uzytkownicy/Index" class="tab-link">Lista aktywnych klientów</a>
            <a href="/Uzytkownicy/Zapomniani" class="tab-link active-danger">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
                Zablokowani użytkownicy
            </a>
        </div>

        <div class="search-card">
            <div class="search-input-wrapper">
                <svg class="search-icon-svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <input type="text" class="search-input" placeholder="Szukaj zablokowanych po: imię i nazwisko...">
            </div>
        </div>

        <div class="table-card">
            <table class="custom-table danger-table">
                <thead>
                    <tr>
                        <th>Czytelnik</th>
                        <th>Identyfikator (Karta)</th>
                        <th>Zablokowany przez</th>
                        <th>ID Administratora</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="td-blocked-user">
                            <svg class="danger-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                                <line x1="12" y1="9" x2="12" y2="13"></line>
                                <line x1="12" y1="17" x2="12.01" y2="17"></line>
                            </svg>
                            Anna Nowak
                        </td>
                        <td>
                            <span class="badge-id">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2" ry="2"></rect><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                                LIB-88451-B
                            </span>
                        </td>
                        <td class="td-grey">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                            Michał Szef
                        </td>
                        <td><span class="badge-admin">ADM-001</span></td>
                        <td class="td-action"><a href="#" class="link-danger">Zobacz profil</a></td>
                    </tr>
                    <tr>
                        <td class="td-blocked-user">
                            <svg class="danger-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                                <line x1="12" y1="9" x2="12" y2="13"></line>
                                <line x1="12" y1="17" x2="12.01" y2="17"></line>
                            </svg>
                            Agnieszka Szymańska
                        </td>
                        <td>
                            <span class="badge-id">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2" ry="2"></rect><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                                LIB-22567-H
                            </span>
                        </td>
                        <td class="td-grey">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                            Piotr Wiśniewski
                        </td>
                        <td><span class="badge-admin">ADM-002</span></td>
                        <td class="td-action"><a href="#" class="link-danger">Zobacz profil</a></td>
                    </tr>
                </tbody>
            </table>
        </div>

    </main>
</div>