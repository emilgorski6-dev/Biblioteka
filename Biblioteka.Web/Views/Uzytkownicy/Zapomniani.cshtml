@model List<Biblioteka.Web.Models.UzytkownikListItemViewModel>

@{
    ViewData["Title"] = "Zapomnieni użytkownicy";
}

<div class="admin-wrapper">
    @* --- BOCZNY PASEK NAWIGACJI --- *@
    <aside class="sidebar">
        <div class="sidebar-header">
            <h3 class="sidebar-title">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E67E22" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
                Panel Admina
            </h3>
            <p class="sidebar-subtitle">Zarządzanie systemem Biblioteka Nova</p>
        </div>

        <nav class="sidebar-nav">
            <a href="/Uzytkownicy/Index" class="sidebar-link active">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                </svg>
                Klienci / Wyszukiwanie
            </a>
            <a href="/Uzytkownicy/Dodaj" class="sidebar-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="8.5" cy="7" r="4"></circle>
                    <line x1="20" y1="8" x2="20" y2="14"></line>
                    <line x1="23" y1="11" x2="17" y2="11"></line>
                </svg>
                Dodaj użytkownika
            </a>
        </nav>
    </aside>

    @* --- GŁÓWNA TREŚĆ --- *@
    <main class="admin-content">
        
        <div class="page-header">
            <h1 class="page-title">Klienci Biblioteki</h1>
            <p class="page-description">Przeszukuj listę użytkowników. W zakładce zapomnianych możesz zarządzać kontami wymagającymi interwencji administratora.</p>
        </div>

        @* --- ZAKŁADKI --- *@
        <div style="display: flex; gap: 2rem; border-bottom: 1px solid #e2e8f0; margin-bottom: 2rem;">
            <a href="/Uzytkownicy/Index" style="padding-bottom: 0.75rem; text-decoration: none; color: #64748b; font-weight: 600;">
                Lista aktywnych klientów
            </a>
            <a href="/Uzytkownicy/Zapomniani" style="padding-bottom: 0.75rem; text-decoration: none; color: #ef4444; font-weight: 600; border-bottom: 2px solid #ef4444; display: flex; align-items: center; gap: 8px;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                    <line x1="12" y1="8" x2="12" y2="12"></line>
                    <line x1="12" y1="16" x2="12.01" y2="16"></line>
                </svg>
                Zapomniani użytkownicy
            </a>
        </div>

        @* --- TABELA Z WYNIKAMI --- *@
        <div style="background: #ffffff; border: 1px solid #1e293b; border-radius: 8px; overflow: hidden;">
            <table class="custom-table" style="width: 100%; border-collapse: collapse; text-align: left;">
                <thead>
                    <tr style="border-bottom: 1px solid #e2e8f0;">
                        <th style="padding: 1rem 1.5rem; font-weight: 600; font-size: 0.9rem; color: #991b1b; background: #fffaf9;">Czytelnik</th>
                        <th style="padding: 1rem 1.5rem; font-weight: 600; font-size: 0.9rem; color: #991b1b; background: #fffaf9;">Identyfikator (Karta)</th>
                        <th style="padding: 1rem 1.5rem; font-weight: 600; font-size: 0.9rem; color: #991b1b; background: #fffaf9;">Zapomniany przez</th>
                        <th style="padding: 1rem 1.5rem; font-weight: 600; font-size: 0.9rem; color: #991b1b; background: #fffaf9;">ID Administratora</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var user in Model)
                {
                    <tr style="border-bottom: 1px solid #e2e8f0;">
                        <td style="padding: 1.25rem 1.5rem; font-weight: 600; color: #1e293b;">
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="#fee2e2" stroke="#ef4444" stroke-width="2">
                                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                                    <line x1="12" y1="9" x2="12" y2="13"></line>
                                    <line x1="12" y1="17" x2="12.01" y2="17"></line>
                                </svg>
                                @user.Imie @user.Nazwisko
                            </div>
                        </td>
                        <td style="padding: 1.25rem 1.5rem; color: #64748b;">
                            <div style="display: flex; align-items: center; gap: 8px; background: #f8fafc; padding: 4px 8px; border-radius: 4px; border: 1px solid #e2e8f0; width: max-content; font-size: 0.9rem;">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="5" width="18" height="14" rx="2" ry="2"></rect>
                                    <line x1="3" y1="10" x2="21" y2="10"></line>
                                </svg>
                                LIB-88451-B
                            </div>
                        </td>
                        <td style="padding: 1.25rem 1.5rem; color: #64748b; font-size: 0.9rem;">
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="12" cy="7" r="4"></circle>
                                </svg>
                                Michał Szef
                            </div>
                        </td>
                        <td style="padding: 1.25rem 1.5rem;">
                            <span style="background: #fef2f2; color: #ef4444; border: 1px solid #fecaca; padding: 4px 10px; border-radius: 4px; font-size: 0.8rem; font-weight: 600;">
                                ADM-001
                            </span>
                        </td>
                    </tr>
                }
                
                @* Przypadek gdy nie ma żadnych zapomnieni użytkowników *@
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" style="text-align: center; padding: 40px; color: #9ca3af;">Nie znaleziono zapomnieni użytkowników.</td>
                    </tr>
                }
                </tbody>        
            </table>
        </div>

    </main>
</div>