@model List<Biblioteka.Web.Models.UzytkownikListItemViewModel>

@{
    ViewData["Title"] = "Zapomniani Użytkownicy";
}

<div class="admin-wrapper">
    @* --- PASEK BOCZNY --- *@
    <aside class="sidebar">
        <div class="sidebar-header">
            <h3 class="sidebar-title">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E67E22" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
                Panel Admina
            </h3>
            <p class="sidebar-subtitle">Zarządzanie systemem Biblioteka Nova</p>
        </div>

        <nav class="sidebar-nav">
            <a href="/Uzytkownicy/Index" class="sidebar-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                </svg>
                Klienci / Wyszukiwanie
            </a>
            <a href="/Uzytkownicy/Zapomniani" class="sidebar-link active">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="15" y1="9" x2="9" y2="15"></line>
                    <line x1="9" y1="9" x2="15" y2="15"></line>
                </svg>
                Zapomniani użytkownicy
            </a>
        </nav>
    </aside>

    <main class="admin-content">
        <div class="page-header">
            <h1 class="page-title">Zapomniani Użytkownicy</h1>
            <p class="page-description">Lista kont wymagających uwagi administratora ze względu na blokady systemowe.</p>
        </div>

        <div class="tab-container">
            <a href="/Uzytkownicy/Index" class="tab-link">Lista aktywnych klientów</a>
            <a href="/Uzytkownicy/Zapomniani" class="tab-link active-danger">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
                Zapomniani użytkownicy
            </a>
        </div>

        @* --- SEKACJA FILTRÓW (SZUKANIE) --- *@
        <div class="filters-card">
            <form method="get" asp-action="Zapomniani" class="filters-row">
                <div class="filter-group">
                    <label class="filter-label">Login</label>
                    <div class="filter-input-wrapper">
                        <svg class="filter-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                        <input type="text" name="searchLogin" class="filter-input" placeholder="Szukaj..." value="@ViewBag.CurrentLogin">
                    </div>
                    <span class="results-count">Zapomnianych: @Model.Count</span>
                </div>

                <div class="filter-group" style="flex: 1.5;">
                    <label class="filter-label">Imię / Nazwisko</label>
                    <div class="filter-input-wrapper">
                        <svg class="filter-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                        <input type="text" name="searchName" class="filter-input" placeholder="Wpisz dane..." value="@ViewBag.CurrentName">
                    </div>
                </div>

                <div class="filter-group">
                    <label class="filter-label">PESEL</label>
                    <div class="filter-input-wrapper">
                        <svg class="filter-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        </svg>
                        <input type="text" name="searchPesel" class="filter-input" placeholder="np. 900..." value="@ViewBag.CurrentPesel">
                    </div>
                </div>

                <div class="filter-actions">
                    <button type="submit" style="display:none;"></button>
                    <a href="/Uzytkownicy/Zapomniani" class="btn-clear" style="text-decoration:none;">Wyczyść</a>
                </div>
            </form>
        </div>

        @* --- TABELA (ZMIENIONA KLASA NA table-card-full) --- *@
        <div class="table-card-full">
            <div class="table-section-header">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2">
                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                    <line x1="12" y1="9" x2="12" y2="13"></line>
                    <line x1="12" y1="17" x2="12.01" y2="17"></line>
                </svg>
                Wymagana interwencja
            </div>

            <table class="custom-table danger-table">
                <thead>
                    <tr>
                        <th>Login</th>
                        <th>Imię i Nazwisko</th>
                        <th>PESEL</th>
                        <th>Status</th>
                        <!--<th class="text-right">Akcja</th> !-->
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="td-bold">@user.Login</td>
                            <td>@user.Imie @user.Nazwisko</td>
                            <td class="td-grey">@user.Pesel</td>
                            <td>
                                <span class="badge-status blocked">Zapomniany</span>
                            </td>
                            <td class="text-right">
                                <a asp-action="Szczegoly" asp-route-login="@user.Login" class="link-danger">Zobacz profil</a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="table-empty">Brak zapomnianych użytkowników spełniających kryteria.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </main>
</div>