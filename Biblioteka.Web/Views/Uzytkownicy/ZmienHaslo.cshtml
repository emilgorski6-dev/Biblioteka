@model Biblioteka.Web.Models.ZmienHasloViewModel

<div class="profile-wrapper">
    <h2>Zmiana hasła użytkownika</h2>
    <p>Użytkownik: <strong>@Model.PelnaNazwa (@Model.Login)</strong></p>

    <div class="details-container-card">
        <form asp-action="ZmienHaslo" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Login" />

            <div class="form-group" style="margin-bottom: 20px;">
                <label>Wpisz nowe hasło:</label>
                <input asp-for="NoweHaslo" class="form-control" type="password" style="width: 100%; padding: 8px;" />
                <span asp-validation-for="NoweHaslo" class="text-danger"
                      style="color: #e74c3c; font-size: 13px;"></span>
            </div>

            <div class="form-actions" style="display: flex; gap: 10px;">
                <button type="submit" class="btn-submit"
                        style="background: #E67E22; color: white; border: none; padding: 10px 20px; cursor: pointer;">
                    Zapisz hasło
                </button>
                @* Scenariusz alternatywny: Anuluj *@
                <a href="/Uzytkownicy/Szczegoly?login=@Model.Login" class="btn-cancel"
                   style="background: #bdc3c7; color: black; text-decoration: none; padding: 10px 20px; border-radius: 7px; display: inline-block;">
                    Anuluj
                </a>
            </div>
        </form>
    </div>
</div>